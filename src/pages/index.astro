---
import '../styles/globals.css';
import AudioWave from '../components/AudioWave.astro';
import BentoGrid from '../components/BentoGrid.astro';
import ClientShowcase from '../components/ClientShowcase.astro';
import RoutingVisualizer from '../components/RoutingVisualizer.astro';
import etcherRelease from '../data/snapdog-etcher-release.json';

const etcherDownloadBase = `https://github.com/SnapDogRocks/snapdog-etcher/releases/download/${etcherRelease.tag}`;
const etcherInstallers = {
  mac: { label: 'macOS · Apple silicon + Intel', file: etcherRelease.assets.macosUniversalDmg },
  windows: { label: 'Windows · x64', file: etcherRelease.assets.windowsX64Exe },
  linuxArm64: { label: 'Linux · ARM64', file: etcherRelease.assets.linuxArm64Zip },
  linuxX64: { label: 'Linux · x64', file: etcherRelease.assets.linuxX64Zip },
};
---

<html lang="en" class="scroll-smooth font-sans overflow-x-hidden">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>SnapDog — Multiroom Audio System</title>
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-white flex flex-col items-center justify-start px-4 sm:px-6 relative overflow-x-hidden select-none selection:bg-amber-500/20 selection:text-amber-200">
    
    <!-- Visually hidden main heading for SEO / Accessibility -->
    <h1 class="sr-only">SnapDog — Synchronized Multiroom Audio System</h1>

    <!-- Hero background image -->
    <div class="absolute inset-0 w-full h-[100dvh] pointer-events-none">
      <img src="/snapdog-hero.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/60"></div>
      <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-b from-transparent to-[#0a0a0a]"></div>
    </div>

    <!-- Background glows (below hero) -->
    <div class="absolute top-[60%] left-1/3 w-[500px] h-[500px] bg-amber-500/[0.02] rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute top-[80%] right-1/4 w-[600px] h-[600px] bg-amber-500/[0.03] rounded-full blur-[150px] pointer-events-none"></div>

    <!-- Hero Header / Introduction Section -->
    <header class="relative z-10 w-full max-w-3xl min-h-[100dvh] flex flex-col items-center justify-between pt-5 pb-6 text-center">
      
      <!-- Top empty placeholder to distribute middle content -->
      <div class="h-1"></div>

      <!-- Hero Content Stack -->
      <div class="flex flex-col items-center gap-6 w-full">
        <!-- Logo -->
        <div class="relative">
          <div class="absolute inset-0 blur-3xl bg-amber-400/15 rounded-full scale-110"></div>
          <img src="/logo.svg" alt="SnapDog" class="relative w-48 h-48 sm:w-56 sm:h-56" />
        </div>

        <!-- Beta badge -->
        <span class="inline-flex items-center px-3 py-0.5 rounded-full text-[11px] font-medium tracking-wide uppercase border border-amber-400/30 bg-amber-400/5 text-amber-300 backdrop-blur-sm -mt-3">Beta</span>

        <!-- Tagline -->
        <p class="text-lg sm:text-xl text-neutral-300 max-w-lg leading-relaxed font-light">
          Multi-zone audio controller with AirPlay, Spotify, Subsonic, <abbr title="Message Queuing Telemetry Transport">MQTT</abbr>, and <abbr title="Konnex building automation standard">KNX</abbr> integration.
        </p>

        <!-- Interactive Audio Wave -->
        <AudioWave />

        <!-- A guided default with progressively disclosed alternatives. -->
        <div class="flex flex-col items-center gap-3 w-full max-w-2xl mt-[6px] px-4 sm:px-0">
          <div class="flex flex-col sm:flex-row justify-center gap-3 w-full">
            <a
              id="etcher-download"
              href={etcherRelease.releaseUrl}
              class="group relative flex flex-1 items-center justify-center gap-3 overflow-hidden rounded-xl bg-amber-500 px-6 py-4 text-sm font-semibold text-black shadow-[0_8px_30px_rgba(245,158,11,0.2)] transition hover:bg-amber-400 hover:shadow-[0_8px_35px_rgba(245,158,11,0.3)]"
              aria-label="Download SnapDog Etcher for this computer"
            >
              <span class="pointer-events-none absolute -right-7 top-2 w-24 rotate-45 border-y border-amber-300/30 bg-neutral-950 py-0.5 text-center text-[8px] font-bold uppercase tracking-[0.22em] text-amber-300 shadow-sm" aria-hidden="true">Beta</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
              <span class="flex flex-col items-start leading-tight">
                <span>Download SnapDog Etcher</span>
                <span id="etcher-platform" class="mt-1 text-[10px] font-medium uppercase tracking-wider text-black/65">Detecting your platform…</span>
              </span>
            </a>

            <a
              href="/docs/install-docker"
              class="group relative flex flex-1 items-center justify-center gap-3 overflow-hidden rounded-xl border border-white/15 bg-white/[0.05] px-6 py-4 text-sm font-semibold text-white backdrop-blur-sm transition hover:border-white/25 hover:bg-white/[0.09]"
              aria-label="Run SnapDog with Docker on an existing server or NAS"
            >
              <span class="pointer-events-none absolute -right-7 top-2 w-24 rotate-45 border-y border-amber-200/50 bg-amber-400 py-0.5 text-center text-[8px] font-bold uppercase tracking-[0.22em] text-neutral-950 shadow-sm" aria-hidden="true">Beta</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M8 8V6a4 4 0 0 1 8 0v2"/><path d="M9 14h.01"/><path d="M15 14h.01"/></svg>
              <span class="flex flex-col items-start leading-tight">
                <span>Run on your server</span>
                <span class="mt-1 text-[10px] font-medium uppercase tracking-wider text-neutral-400">Docker · NAS · existing Linux</span>
              </span>
            </a>
          </div>

          <p class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-xs leading-relaxed text-neutral-400">
            <span>Need Etcher for another platform or architecture?</span>
            <a href={etcherRelease.releaseUrl} class="text-neutral-300 underline decoration-white/20 underline-offset-4 transition hover:text-amber-300">View all downloads</a>
            <span aria-hidden="true" class="text-neutral-600">·</span>
            <a href="/docs/install-direct" class="text-neutral-300 underline decoration-white/20 underline-offset-4 transition hover:text-amber-300">Native packages</a>
            <span aria-hidden="true" class="text-neutral-600">·</span>
            <a href="/docs/snapdog-os#manual-image-download" class="text-neutral-300 underline decoration-white/20 underline-offset-4 transition hover:text-amber-300">Raw images</a>
          </p>
        </div>
      </div>

      <!-- Quick Scroll Indicator -->
      <a
        href="#architecture"
        class="flex flex-col items-center gap-2 text-[10px] font-mono tracking-widest text-neutral-500 uppercase hover:text-amber-400 transition-colors duration-300 group cursor-pointer mt-[70px] sm:mt-[30px]"
        aria-label="Scroll to routing and sync architecture visualizer"
      >
        <span>Explore</span>
        <span class="animate-bounce text-sm group-hover:translate-y-0.5 transition-transform duration-300">↓</span>
      </a>
    </header>

    <!-- Main visual presentation sections -->
    <main class="w-full flex flex-col items-center relative z-10">
      
      <!-- Interactive Signal Routing Visualizer Section -->
      <RoutingVisualizer />

      <!-- Bento Features Section -->
      <BentoGrid />

      <!-- Native Apple Client Showcase Section -->
      <ClientShowcase />

      <!-- CTA to Docs -->
      <section class="py-24 flex flex-col items-center gap-6 text-center max-w-xl">
        <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight font-display text-white">Ready to integrate?</h2>
        <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">
          SnapDog is open source and runs on standard Raspberry Pi devices. Check out our comprehensive setup guides, hardware recommendations, and REST API documentation to get started.
        </p>
        <a
          href="/docs/introduction"
          class="mt-4 px-8 py-3 rounded-full bg-amber-500 text-black hover:bg-amber-400 font-semibold tracking-wide transition shadow-[0_4px_20px_rgba(245,158,11,0.2)] hover:shadow-[0_4px_25px_rgba(245,158,11,0.3)]"
          aria-label="Navigate to SnapDog documentation introduction page"
        >
          Go to Documentation
        </a>
      </section>

    </main>

    <!-- Footer -->
    <footer class="w-full max-w-5xl py-12 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-6 text-xs text-neutral-400 relative z-10">
      <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
        <p>© 2026 Fabian Schmieder</p>
        <a href="/docs/license" class="inline-flex hover:opacity-100 opacity-80 transition-opacity" aria-label="Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International License">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 165 30" width="145" height="26" class="text-neutral-500 hover:text-amber-400 transition-colors duration-300">
            <!-- CC (Creative Commons) -->
            <circle cx="10" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <path d="M 9.5,12.5 C 8,12.5 7,13.5 7,15 C 7,16.5 8,17.5 9.5,17.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            <path d="M 13,12.5 C 11.5,12.5 10.5,13.5 10.5,15 C 10.5,16.5 11.5,17.5 13,17.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            
            <!-- BY (Attribution) -->
            <circle cx="28" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <circle cx="28" cy="11.8" r="1.5" fill="currentColor" />
            <path d="M 28,13.8 C 26.8,13.8 26.3,14.8 26.3,16.3 L 27.1,16.3 L 27.1,20 L 28,20 L 28,18.2 L 28,20 L 28.9,20 L 28.9,16.3 L 29.7,16.3 C 29.7,14.8 29.2,13.8 28,13.8 Z" fill="currentColor" />

            <!-- NC (Non-Commercial) -->
            <circle cx="46" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <line x1="46" y1="10.5" x2="46" y2="19.5" stroke="currentColor" stroke-width="1" />
            <path d="M 47.5,12.8 C 47.5,11.8 44.5,11.8 44.5,13.2 C 44.5,15 47.5,14.5 47.5,16.2 C 47.5,18 44.5,18 44.5,17.2" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
            <line x1="43" y1="17.5" x2="49" y2="12.5" stroke="currentColor" stroke-width="1.2" />

            <!-- SA (Share-Alike) -->
            <circle cx="64" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <path d="M 67.2,14.2 C 67.2,12.2 65.5,10.5 63.5,10.5 C 61,10.5 59.8,12.8 59.8,15 C 59.8,17.2 61,19.5 63.5,19.5 C 65.5,19.5 67.2,17.8 67.2,15.8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
            <polyline points="65.5,17.2 67.2,15.8 68.9,17.2" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />

            <!-- Text -->
            <text x="78" y="18" fill="currentColor" font-family="monospace" font-size="8.5" font-weight="bold" letter-spacing="0.5">BY-NC-SA 4.0</text>
          </svg>
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-6 items-center">
        <a href="/docs/introduction" class="hover:text-neutral-300" aria-label="Read SnapDog documentation">Docs</a>
        <a href="https://github.com/SnapDogRocks/snapdog-os" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-300" aria-label="View SnapDog GitHub repository">GitHub</a>
        <a href="/docs/snapdog-os" class="hover:text-neutral-300" aria-label="Read SnapDog OS installation guide and get download links">SnapDog OS</a>
        <a href="/docs/license" class="hover:text-neutral-300" aria-label="Read SnapDog licensing information">License</a>
        <a href="/imprint" class="hover:text-neutral-300" aria-label="Read SnapDog imprint">Imprint</a>
        <a href="/privacy" class="hover:text-neutral-300" aria-label="Read SnapDog privacy policy">Privacy</a>
      </div>
    </footer>

    <script is:inline define:vars={{ releaseBase: etcherDownloadBase, installers: etcherInstallers }}>

      const download = document.getElementById('etcher-download');
      const platformLabel = document.getElementById('etcher-platform');

      function chooseInstaller(platform, architecture = '') {
        const os = platform.toLowerCase();
        const arch = architecture.toLowerCase();
        if (os.includes('mac')) return installers.mac;
        if (os.includes('win')) return installers.windows;
        if (os.includes('linux')) {
          return /arm64|aarch64/.test(arch) ? installers.linuxArm64 : installers.linuxX64;
        }
        return null;
      }

      function applyInstaller(installer) {
        if (!installer || !download || !platformLabel) return;
        download.href = `${releaseBase}/${installer.file}`;
        platformLabel.textContent = installer.label;
      }

      const userAgent = navigator.userAgent || '';
      const fallbackPlatform = navigator.platform || userAgent;
      const fallbackArchitecture = /arm64|aarch64/i.test(userAgent) ? 'arm64' : 'x64';
      const isMobile = /Android|iPhone|iPad|iPod/i.test(userAgent);
      const fallback = isMobile ? null : chooseInstaller(fallbackPlatform, fallbackArchitecture);
      applyInstaller(fallback);

      if (!fallback && platformLabel) platformLabel.textContent = 'Choose your platform';

      if (navigator.userAgentData?.getHighEntropyValues) {
        navigator.userAgentData
          .getHighEntropyValues(['architecture', 'bitness'])
          .then(({ architecture, bitness }) => {
            const preciseArchitecture = `${architecture || ''}${bitness || ''}`;
            applyInstaller(chooseInstaller(navigator.userAgentData.platform || fallbackPlatform, preciseArchitecture));
          })
          .catch(() => { /* retain the synchronous fallback */ });
      }
    </script>

  </body>
</html>
