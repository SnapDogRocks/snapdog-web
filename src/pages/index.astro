---
import '../styles/globals.css';
import AudioWave from '../components/AudioWave.astro';
import BentoGrid from '../components/BentoGrid.astro';
import RoutingVisualizer from '../components/RoutingVisualizer.astro';
import SetupWalkthrough from '../components/SetupWalkthrough.astro';

// Fetch the latest version from GitHub at build time
let version = 'v0.2.0';
try {
  const res = await fetch(
    'https://api.github.com/repos/SnapDogRocks/snapdog-os/releases/latest'
  );
  if (res.ok) {
    const data = await res.json();
    version = data.tag_name ?? 'v0.2.0';
  }
} catch {
  // Use fallback if offline or rate-limited during build
}
---

<html lang="en" class="scroll-smooth font-sans">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>SnapDog — Multiroom Audio System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-white flex flex-col items-center justify-start px-4 sm:px-6 relative overflow-x-hidden select-none selection:bg-amber-500/20 selection:text-amber-200">
    
    <!-- Visually hidden main heading for SEO / Accessibility -->
    <h1 class="sr-only">SnapDog — Synchronized Multiroom Audio System</h1>

    <!-- Background glows -->
    <div class="absolute top-[20%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-[60%] left-1/3 w-[500px] h-[500px] bg-amber-500/[0.02] rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute top-[80%] right-1/4 w-[600px] h-[600px] bg-amber-500/[0.03] rounded-full blur-[150px] pointer-events-none"></div>

    <!-- Hero Header / Introduction Section -->
    <header class="relative z-10 w-full max-w-2xl min-h-[100dvh] flex flex-col items-center justify-between pt-10 pb-6 text-center">
      
      <!-- Top empty placeholder to distribute middle content -->
      <div class="h-1"></div>

      <!-- Hero Content Stack -->
      <div class="flex flex-col items-center gap-6 w-full">
        <!-- Logo -->
        <div class="relative">
          <div class="absolute inset-0 blur-3xl bg-amber-400/15 rounded-full scale-110"></div>
          <img src="/logo.svg" alt="SnapDog" class="relative w-48 h-48 sm:w-56 sm:h-56" />
        </div>

        <!-- Tagline -->
        <p class="text-lg sm:text-xl text-neutral-300 max-w-lg leading-relaxed font-light">
          Multi-zone audio controller with AirPlay, Spotify, Subsonic, <abbr title="Message Queuing Telemetry Transport">MQTT</abbr>, and <abbr title="Konnex building automation standard">KNX</abbr> integration.
        </p>

        <!-- Interactive Audio Wave -->
        <AudioWave />

        <!-- Info and download grids -->
        <div class="grid grid-cols-[2fr_1fr] gap-3 w-full max-w-sm font-mono text-left text-xs mt-[6px]">
          
          <!-- Dropdown Selector (replaces DownloadSelector.tsx component) -->
          <div class="flex items-stretch gap-3 w-full max-w-sm col-span-2 sm:col-span-1">
            <div class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10 flex-1 min-w-0">
              <span class="text-[9px] uppercase font-semibold text-neutral-400 tracking-wider">Model</span>
              <select
                id="model-select"
                class="mt-1 bg-transparent text-white text-sm font-semibold tracking-tight outline-none cursor-pointer"
                aria-label="Select Raspberry Pi Hardware Model"
              >
                <option value="pi5" class="bg-[#0a0a0a]">Raspberry Pi 5</option>
                <option value="pi4" class="bg-[#0a0a0a]" selected>Raspberry Pi 4</option>
                <option value="pi3" class="bg-[#0a0a0a]">Raspberry Pi 3</option>
              </select>
            </div>
            <a
              id="download-btn"
              href="https://updates.snapdog.cc/os/images/snapdog-os-pi4-beta.img.gz"
              class="flex items-center justify-center w-14 rounded-xl bg-amber-500 text-black hover:bg-amber-400 transition-colors shrink-0"
              title="Download image"
              aria-label="Download SnapDog OS image for selected model"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </a>
          </div>

          <div class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10">
            <span class="text-[9px] uppercase font-semibold text-neutral-400 tracking-wider">Version</span>
            <span class="font-semibold text-white mt-1 tabular-nums tracking-tight text-sm">{version}</span>
          </div>

          <a
            href="/docs/introduction"
            class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10 hover:bg-white/[0.06] hover:border-white/20 transition-all group"
            aria-label="Read SnapDog setup documentation guides"
          >
            <div class="flex justify-between items-center w-full">
              <span class="text-[9px] uppercase font-semibold text-neutral-400 tracking-wider">Documentation</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-400 group-hover:text-amber-400 transition-colors duration-300"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 6h10"/><path d="M6 10h10"/><path d="M6 14h10"/></svg>
            </div>
            <span class="font-semibold text-amber-400 mt-1 group-hover:underline tracking-tight text-sm">
              Read guides ↗
            </span>
          </a>

          <a
            href="https://github.com/SnapDogRocks/snapdog-os"
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10 hover:bg-white/[0.06] hover:border-white/20 transition-all group"
            aria-label="View SnapDog OS source code on GitHub"
          >
            <div class="flex justify-between items-center w-full">
              <span class="text-[9px] uppercase font-semibold text-neutral-400 tracking-wider">Source</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-400 group-hover:text-amber-400 transition-colors duration-300"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </div>
            <span class="font-semibold text-amber-400 mt-1 group-hover:underline tracking-tight text-sm">
              GitHub ↗
            </span>
          </a>
        </div>
      </div>

      <!-- Quick Scroll Indicator -->
      <a
        href="#architecture"
        class="flex flex-col items-center gap-2 text-[10px] font-mono tracking-widest text-neutral-500 uppercase hover:text-amber-400 transition-colors duration-300 group cursor-pointer"
        aria-label="Scroll to routing and sync architecture visualizer"
      >
        <span>Explore Architecture</span>
        <span class="animate-bounce text-sm group-hover:translate-y-0.5 transition-transform duration-300">↓</span>
      </a>
    </header>

    <!-- Main visual presentation sections -->
    <main class="w-full flex flex-col items-center relative z-10">
      
      <!-- Interactive Signal Routing Visualizer Section -->
      <RoutingVisualizer />

      <!-- Bento Features Section -->
      <BentoGrid />

      <!-- Captive Portal Provisioning Setup Section -->
      <SetupWalkthrough />

      <!-- CTA to Docs -->
      <section class="py-24 flex flex-col items-center gap-6 text-center max-w-xl">
        <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight font-display text-white">Ready to integrate?</h2>
        <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">
          SnapDog is open source and runs on standard Raspberry Pi devices. Check out our comprehensive setup guides, hardware recommendations, and REST API documentation to get started.
        </p>
        <a
          href="/docs/introduction"
          class="mt-4 px-8 py-3 rounded-full bg-amber-500 text-black hover:bg-amber-400 font-semibold tracking-wide transition shadow-[0_4px_20px_rgba(245,158,11,0.2)] hover:shadow-[0_4px_25px_rgba(245,158,11,0.3)]"
          aria-label="Navigate to SnapDog documentation introduction page"
        >
          Go to Documentation
        </a>
      </section>

    </main>

    <!-- Footer -->
    <footer class="w-full max-w-5xl py-12 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-6 text-xs text-neutral-400 relative z-10">
      <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
        <p>© 2026 Fabian Schmieder</p>
        <a href="/docs/license" class="inline-flex hover:opacity-100 opacity-80 transition-opacity" aria-label="Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International License">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 165 30" width="145" height="26" class="text-neutral-500 hover:text-amber-400 transition-colors duration-300">
            <!-- CC (Creative Commons) -->
            <circle cx="10" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <path d="M 9.5,12.5 C 8,12.5 7,13.5 7,15 C 7,16.5 8,17.5 9.5,17.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            <path d="M 13,12.5 C 11.5,12.5 10.5,13.5 10.5,15 C 10.5,16.5 11.5,17.5 13,17.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            
            <!-- BY (Attribution) -->
            <circle cx="28" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <circle cx="28" cy="11.8" r="1.5" fill="currentColor" />
            <path d="M 28,13.8 C 26.8,13.8 26.3,14.8 26.3,16.3 L 27.1,16.3 L 27.1,20 L 28,20 L 28,18.2 L 28,20 L 28.9,20 L 28.9,16.3 L 29.7,16.3 C 29.7,14.8 29.2,13.8 28,13.8 Z" fill="currentColor" />

            <!-- NC (Non-Commercial) -->
            <circle cx="46" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <line x1="46" y1="10.5" x2="46" y2="19.5" stroke="currentColor" stroke-width="1" />
            <path d="M 47.5,12.8 C 47.5,11.8 44.5,11.8 44.5,13.2 C 44.5,15 47.5,14.5 47.5,16.2 C 47.5,18 44.5,18 44.5,17.2" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
            <line x1="43" y1="17.5" x2="49" y2="12.5" stroke="currentColor" stroke-width="1.2" />

            <!-- SA (Share-Alike) -->
            <circle cx="64" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
            <path d="M 67.2,14.2 C 67.2,12.2 65.5,10.5 63.5,10.5 C 61,10.5 59.8,12.8 59.8,15 C 59.8,17.2 61,19.5 63.5,19.5 C 65.5,19.5 67.2,17.8 67.2,15.8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
            <polyline points="65.5,17.2 67.2,15.8 68.9,17.2" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />

            <!-- Text -->
            <text x="78" y="18" fill="currentColor" font-family="monospace" font-size="8.5" font-weight="bold" letter-spacing="0.5">BY-NC-SA 4.0</text>
          </svg>
        </a>
      </div>
      <div class="flex gap-6 items-center">
        <a href="/docs/introduction" class="hover:text-neutral-300" aria-label="Read SnapDog documentation">Docs</a>
        <a href="https://github.com/SnapDogRocks/snapdog-os" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-300" aria-label="View SnapDog GitHub repository">GitHub</a>
        <a href="https://updates.snapdog.cc/os/images/snapdog-os-pi4-beta.img.gz" class="hover:text-neutral-300" aria-label="Download latest SnapDog OS image">Download OS</a>
        <a href="/docs/license" class="hover:text-neutral-300" aria-label="Read SnapDog licensing information">License</a>
      </div>
    </footer>

    <!-- Client-side javascript to handle download URL swapping -->
    <script is:inline>
      const select = document.getElementById('model-select');
      const btn = document.getElementById('download-btn');
      if (select && btn) {
        select.addEventListener('change', (e) => {
          const model = e.target.value;
          btn.href = `https://updates.snapdog.cc/os/images/snapdog-os-${model}-beta.img.gz`;
          btn.setAttribute('aria-label', `Download SnapDog OS image for Raspberry Pi ${model.replace('pi', '')}`);
        });
      }
    </script>
  </body>
</html>
