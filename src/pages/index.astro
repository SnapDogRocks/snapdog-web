---
import '../styles/globals.css';
import AudioWave from '../components/AudioWave.astro';
import BentoGrid from '../components/BentoGrid.astro';
import RoutingVisualizer from '../components/RoutingVisualizer.astro';
import SetupWalkthrough from '../components/SetupWalkthrough.astro';

// Fetch the latest version from GitHub at build time
let version = 'v0.2.0';
try {
  const res = await fetch(
    'https://api.github.com/repos/SnapDogRocks/snapdog-os/releases/latest'
  );
  if (res.ok) {
    const data = await res.json();
    version = data.tag_name ?? 'v0.2.0';
  }
} catch {
  // Use fallback if offline or rate-limited during build
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>SnapDog — Multiroom Audio System</title>
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-white flex flex-col items-center justify-start px-6 relative overflow-x-hidden select-none selection:bg-amber-500/20 selection:text-amber-200">
    
    <!-- Background glows -->
    <div class="absolute top-[20%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-[60%] left-1/3 w-[500px] h-[500px] bg-amber-500/[0.02] rounded-full blur-[140px] pointer-events-none"></div>
    <div class="absolute top-[80%] right-1/4 w-[600px] h-[600px] bg-amber-500/[0.03] rounded-full blur-[150px] pointer-events-none"></div>

    <!-- Hero Header / Introduction Section -->
    <header class="relative z-10 flex flex-col items-center gap-8 max-w-2xl text-center pt-24 pb-16 min-h-[90vh] justify-center">
      <!-- Logo -->
      <div class="relative">
        <div class="absolute inset-0 blur-3xl bg-amber-400/15 rounded-full scale-110"></div>
        <img src="/logo.svg" alt="SnapDog" width="240" height="240" class="relative" />
      </div>

      <!-- Tagline -->
      <p class="text-lg sm:text-xl text-neutral-400 max-w-lg leading-relaxed">
        Multi-zone audio controller with AirPlay, Spotify, Subsonic, MQTT, and KNX integration.
      </p>

      <!-- Interactive Audio Wave -->
      <AudioWave />

      <!-- Info and download grids -->
      <div class="grid grid-cols-[2fr_1fr] gap-3 w-full max-w-sm font-mono text-left text-xs mt-4">
        
        <!-- Dropdown Selector (replaces DownloadSelector.tsx component) -->
        <div class="flex items-stretch gap-3 w-full max-w-sm col-span-2 sm:col-span-1">
          <div class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10 flex-1 min-w-0">
            <span class="text-[9px] uppercase font-semibold text-neutral-500 tracking-wider">Model</span>
            <select
              id="model-select"
              class="mt-1 bg-transparent text-white text-sm font-semibold tracking-tight outline-none cursor-pointer"
            >
              <option value="pi5" class="bg-[#0a0a0a]">Raspberry Pi 5</option>
              <option value="pi4" class="bg-[#0a0a0a]" selected>Raspberry Pi 4</option>
              <option value="pi3" class="bg-[#0a0a0a]">Raspberry Pi 3</option>
            </select>
          </div>
          <a
            id="download-btn"
            href="https://updates.snapdog.cc/os/images/snapdog-os-pi4-beta.img.gz"
            class="flex items-center justify-center w-14 rounded-xl bg-amber-500 text-black hover:bg-amber-400 transition-colors shrink-0"
            title="Download image"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </a>
        </div>

        <div class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10">
          <span class="text-[9px] uppercase font-semibold text-neutral-500 tracking-wider">Version</span>
          <span class="font-semibold text-white mt-1 tabular-nums tracking-tight text-sm">{version}</span>
        </div>

        <a
          href="/docs/introduction"
          class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10 hover:bg-white/[0.06] hover:border-white/20 transition-all group"
        >
          <span class="text-[9px] uppercase font-semibold text-neutral-500 tracking-wider">Documentation</span>
          <span class="font-semibold text-amber-400 mt-1 group-hover:underline tracking-tight text-sm">
            Read guides ↗
          </span>
        </a>

        <a
          href="https://github.com/SnapDogRocks/snapdog-os"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10 hover:bg-white/[0.06] hover:border-white/20 transition-all group"
        >
          <span class="text-[9px] uppercase font-semibold text-neutral-500 tracking-wider">Source</span>
          <span class="font-semibold text-amber-400 mt-1 group-hover:underline tracking-tight text-sm">
            GitHub ↗
          </span>
        </a>

        <a
          href="https://www.gnu.org/licenses/gpl-3.0.html"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col py-3 px-4 rounded-xl bg-white/[0.03] border border-white/10 hover:bg-white/[0.06] hover:border-white/20 transition-all group col-span-2 sm:col-span-1"
        >
          <span class="text-[9px] uppercase font-semibold text-neutral-500 tracking-wider">License</span>
          <span class="font-semibold text-amber-400 mt-1 group-hover:underline tracking-tight text-sm">
            GPL-3.0 ↗
          </span>
        </a>
      </div>

      <!-- Quick Scroll Indicator -->
      <div class="mt-8 flex flex-col items-center gap-2 text-[10px] font-mono tracking-widest text-neutral-500 uppercase">
        <span>Explore Architecture</span>
        <span class="animate-bounce text-sm">↓</span>
      </div>
    </header>

    <!-- Main visual presentation sections -->
    <main class="w-full flex flex-col items-center relative z-10">
      
      <!-- Interactive Signal Routing Visualizer Section (Step 4) -->
      <RoutingVisualizer />

      <!-- Bento Features Section (Step 3) -->
      <BentoGrid />

      <!-- Captive Portal Provisioning Setup Section (Step 5) -->
      <SetupWalkthrough />

      <!-- CTA to Docs -->
      <section class="py-24 flex flex-col items-center gap-6 text-center max-w-xl">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">Ready to integrate?</h2>
        <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">
          SnapDog is open source and runs on standard Raspberry Pi devices. Check out our comprehensive setup guides, hardware recommendations, and REST API documentation to get started.
        </p>
        <a
          href="/docs/introduction"
          class="mt-4 px-8 py-3 rounded-full bg-amber-500 text-black hover:bg-amber-400 font-semibold tracking-wide transition shadow-[0_4px_20px_rgba(245,158,11,0.2)] hover:shadow-[0_4px_25px_rgba(245,158,11,0.3)]"
        >
          Go to Documentation
        </a>
      </section>

    </main>

    <!-- Footer -->
    <footer class="w-full max-w-5xl py-12 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-neutral-600 relative z-10">
      <p>© 2026 Fabian Schmieder</p>
      <div class="flex gap-6">
        <a href="/docs/introduction" class="hover:text-neutral-400">Docs</a>
        <a href="https://github.com/SnapDogRocks/snapdog-os" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-400">GitHub</a>
        <a href="https://updates.snapdog.cc/os/images/snapdog-os-pi4-beta.img.gz" class="hover:text-neutral-400">Download OS</a>
      </div>
    </footer>

    <!-- Client-side javascript to handle download URL swapping -->
    <script is:inline>
      const select = document.getElementById('model-select');
      const btn = document.getElementById('download-btn');
      if (select && btn) {
        select.addEventListener('change', (e) => {
          const model = e.target.value;
          btn.href = `https://updates.snapdog.cc/os/images/snapdog-os-${model}-beta.img.gz`;
        });
      }
    </script>
  </body>
</html>
