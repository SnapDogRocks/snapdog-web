---
// Bento Feature Grid Component for SnapDog Landing Page
---

<section class="w-full max-w-5xl px-4 py-20 flex flex-col gap-12 text-left">
  <div class="flex flex-col gap-3">
    <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight font-display">
      Engineered for <span class="text-amber-400 glow-amber">Hi-Fi</span> Performance
    </h2>
    <p class="text-sm sm:text-base text-neutral-400 max-w-xl">
      SnapDog combines the warmth of physical audio hardware with modern, low-latency synchronizations and smart-home standard interfaces.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Card 1: Snapcast Sync (col-span-2) -->
    <div class="glass-card shadow-glow-card rounded-2xl p-6 md:col-span-2 flex flex-col justify-between overflow-hidden group hover:border-amber-500/30 hover:shadow-glow-amber/5 relative min-h-[300px]">
      <div class="absolute inset-0 bg-gradient-to-tr from-amber-500/0 via-amber-500/0 to-amber-500/[0.02] pointer-events-none"></div>
      
      <div class="relative z-10 flex flex-col gap-2 max-w-md">
        <div class="flex items-center gap-2">
          <span class="px-2 py-0.5 text-[9px] uppercase font-mono tracking-wider bg-green-500/10 border border-green-500/20 text-green-400 rounded-md">Live Sync</span>
          <span class="text-xs font-mono text-neutral-400">&lt; 2ms drift</span>
        </div>
        <h3 class="text-lg font-semibold mt-1">Multi-Room Synchronized Audio</h3>
        <p class="text-xs text-neutral-400 leading-relaxed">
          Powered by Snapcast's synchronized audio architecture. Distributes bit-perfect audio to dozens of client nodes across your home network with microsecond-level synchronization.
        </p>
      </div>

      <!-- Live Sync Animation -->
      <div class="relative h-28 w-full mt-4 flex items-center justify-center">
        <svg viewBox="0 0 400 120" class="w-full h-full overflow-visible select-none">
          <defs>
            <filter id="glow-green" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="2" result="blur" />
              <feComposite in="SourceGraphic" in2="blur" operator="over" />
            </filter>
            <filter id="glow-amber" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="2" result="blur" />
              <feComposite in="SourceGraphic" in2="blur" operator="over" />
            </filter>
            <filter id="glow-sky" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="2" result="blur" />
              <feComposite in="SourceGraphic" in2="blur" operator="over" />
            </filter>
          </defs>

          <!-- Audio Wires -->
          <!-- Wire 1: to Living Room (Green) -->
          <path d="M 200,60 Q 150,30 130,27" fill="none" stroke="#22c55e" stroke-width="1.5" opacity="0.15" />
          <path d="M 200,60 Q 150,30 130,27" fill="none" stroke="#22c55e" stroke-width="1.5" class="animate-flow-green" filter="url(#glow-green)" />

          <!-- Wire 2: to Kitchen (Amber) -->
          <path d="M 200,60 Q 240,55 290,72" fill="none" stroke="#f59e0b" stroke-width="1.5" opacity="0.15" />
          <path d="M 200,60 Q 240,55 290,72" fill="none" stroke="#f59e0b" stroke-width="1.5" class="animate-flow-amber" filter="url(#glow-amber)" />

          <!-- Wire 3: to Patio (Sky) -->
          <path d="M 200,60 Q 170,90 140,97" fill="none" stroke="#0ea5e9" stroke-width="1.5" opacity="0.15" />
          <path d="M 200,60 Q 170,90 140,97" fill="none" stroke="#0ea5e9" stroke-width="1.5" class="animate-flow-sky" filter="url(#glow-sky)" />

          <!-- Central Hub -->
          <g transform="translate(200, 60)">
            <circle cx="0" cy="0" r="16" fill="none" stroke="#f59e0b" stroke-width="1.2" opacity="0.4" class="animate-ping" />
            <circle cx="0" cy="0" r="12" fill="none" stroke="#f59e0b" stroke-width="1" opacity="0.3" />
            <circle cx="0" cy="0" r="28" fill="none" stroke="#f59e0b" stroke-width="1" opacity="0.15" class="animate-pulse" />
            <circle cx="0" cy="0" r="4" fill="#f59e0b" />
          </g>

          <!-- Sync Nodes -->
          <!-- Living Room (Green/Left-Top) -->
          <g transform="translate(30, 15)">
            <rect x="0" y="0" width="100" height="24" rx="6" ry="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="group-hover:stroke-green-500/30 transition-colors" />
            <circle cx="12" cy="12" r="3" fill="#22c55e" />
            <text x="24" y="16" fill="#a3a3a3" font-family="monospace" font-size="10px" class="group-hover:fill-white transition-colors">Living Room</text>
          </g>

          <!-- Kitchen (Amber/Right-Middle) -->
          <g transform="translate(290, 60)">
            <rect x="0" y="0" width="70" height="24" rx="6" ry="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="group-hover:stroke-amber-500/30 transition-colors" />
            <circle cx="12" cy="12" r="3" fill="#f59e0b" />
            <text x="24" y="16" fill="#a3a3a3" font-family="monospace" font-size="10px" class="group-hover:fill-white transition-colors">Kitchen</text>
          </g>

          <!-- Patio (Sky/Left-Bottom) -->
          <g transform="translate(80, 85)">
            <rect x="0" y="0" width="60" height="24" rx="6" ry="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="group-hover:stroke-sky-500/30 transition-colors" />
            <circle cx="12" cy="12" r="3" fill="#0ea5e9" />
            <text x="24" y="16" fill="#a3a3a3" font-family="monospace" font-size="10px" class="group-hover:fill-white transition-colors">Patio</text>
          </g>
        </svg>
      </div>
    </div>

    <!-- Card 2: Parametric EQ (col-span-1) -->
    <div class="glass-card shadow-glow-card rounded-2xl p-6 flex flex-col justify-between overflow-hidden group hover:border-amber-500/30 hover:shadow-glow-amber/5 relative min-h-[300px]">
      <div class="relative z-10 flex flex-col gap-2">
        <span class="px-2 py-0.5 text-[9px] uppercase font-mono tracking-wider bg-amber-500/10 border border-amber-500/20 text-amber-400 rounded-md w-fit"><abbr title="Digital Signal Processor">DSP</abbr> Engine</span>
        <h3 class="text-lg font-semibold mt-1">Parametric Equalizer</h3>
        <p class="text-xs text-neutral-400 leading-relaxed">
          Tweak acoustics to match any environment. Multi-band parametric <abbr title="Equalizer">EQ</abbr> curves configurable per zone to calibrate room audio.
        </p>
      </div>

      <!-- Mini Interactive EQ visualization -->
      <div class="mt-4 h-24 w-full relative bg-black/20 border border-white/5 rounded-xl overflow-hidden px-2 py-3 flex flex-col justify-end">
        <svg viewBox="0 0 200 80" class="w-full h-full overflow-visible">
          <!-- EQ Grid Lines -->
          <line x1="0" y1="40" x2="200" y2="40" stroke="rgba(255,255,255,0.05)" stroke-width="1"></line>
          <line x1="50" y1="0" x2="50" y2="80" stroke="rgba(255,255,255,0.05)" stroke-dasharray="2 2"></line>
          <line x1="100" y1="0" x2="100" y2="80" stroke="rgba(255,255,255,0.05)" stroke-dasharray="2 2"></line>
          <line x1="150" y1="0" x2="150" y2="80" stroke="rgba(255,255,255,0.05)" stroke-dasharray="2 2"></line>
          
          <!-- EQ Curve -->
          <path d="M0,40 Q30,20 60,30 T120,60 T170,15 T200,40" fill="rgba(245, 158, 11, 0.05)" stroke="#f59e0b" stroke-width="2" class="group-hover:stroke-amber-400 transition-colors"></path>
          
          <!-- Draggable Nodes (Static visuals but hover animates) -->
          <circle cx="60" cy="30" r="3.5" fill="#f59e0b" class="group-hover:scale-125 transition-transform duration-300"></circle>
          <circle cx="120" cy="60" r="3.5" fill="#f59e0b" class="group-hover:scale-125 transition-transform duration-300"></circle>
          <circle cx="170" cy="15" r="3.5" fill="#f59e0b" class="group-hover:scale-125 transition-transform duration-300"></circle>
        </svg>
      </div>
    </div>

    <!-- Card 3: Home Assistant (col-span-1) -->
    <div class="glass-card shadow-glow-card rounded-2xl p-6 flex flex-col justify-between overflow-hidden group hover:border-amber-500/30 hover:shadow-glow-amber/5 relative min-h-[260px]">
      <div class="relative z-10 flex flex-col gap-2">
        <span class="px-2 py-0.5 text-[9px] uppercase font-mono tracking-wider bg-sky-500/10 border border-sky-500/20 text-sky-400 rounded-md w-fit"><abbr title="Message Queuing Telemetry Transport">MQTT</abbr></span>
        <h3 class="text-lg font-semibold mt-1">Smart Home Integration</h3>
        <p class="text-xs text-neutral-400 leading-relaxed">
          Expose zones as standard media players. Seamless zero-configuration discovery via Home Assistant over local <abbr title="Message Queuing Telemetry Transport">MQTT</abbr> brokers.
        </p>
      </div>

      <!-- MQTT Telemetry Feed Visual -->
      <div class="mt-4 font-mono text-[9px] text-sky-400 bg-black/40 border border-white/5 rounded-xl p-3 flex flex-col gap-1 min-h-[80px]">
        <div class="flex justify-between border-b border-white/5 pb-1 mb-1 text-neutral-400">
          <span>topic: snapdog/discovery</span>
          <span><abbr title="Message Queuing Telemetry Transport">MQTT</abbr> 3.1</span>
        </div>
        <div class="truncate opacity-80 group-hover:opacity-100 transition-opacity">
          &gt; publish <span class="text-amber-400">"state"</span>: <span class="text-green-400">"playing"</span>
        </div>
        <div class="truncate opacity-60 group-hover:opacity-100 transition-opacity" style="transition-delay: 0.05s;">
          &gt; publish <span class="text-amber-400">"volume"</span>: <span class="text-neutral-300">65</span>
        </div>
        <div class="truncate opacity-40 group-hover:opacity-100 transition-opacity" style="transition-delay: 0.1s;">
          &gt; announce client <span class="text-green-400">"living_room"</span>
        </div>
      </div>
    </div>

    <!-- Card 4: KNX Control (col-span-1) -->
    <div class="glass-card shadow-glow-card rounded-2xl p-6 flex flex-col justify-between overflow-hidden group hover:border-amber-500/30 hover:shadow-glow-amber/5 relative min-h-[260px]">
      <div class="relative z-10 flex flex-col gap-2">
        <span class="px-2 py-0.5 text-[9px] uppercase font-mono tracking-wider bg-purple-500/10 border border-purple-500/20 text-purple-400 rounded-md w-fit">Building Automation</span>
        <h3 class="text-lg font-semibold mt-1"><abbr title="Konnex building automation standard">KNX</abbr> Device Mode</h3>
        <p class="text-xs text-neutral-400 leading-relaxed">
          Connects directly to your <abbr title="Konnex building automation standard">KNX</abbr> building automation system to trigger playback controls using physical wall switches.
        </p>
      </div>

      <!-- KNX bus visual -->
      <div class="mt-4 flex items-center justify-between border border-white/5 rounded-xl bg-black/25 p-3 min-h-[80px] font-mono text-[10px]">
        <div class="flex flex-col gap-1">
          <span class="text-neutral-400 uppercase text-[8px]">Group Address</span>
          <span class="text-purple-400 group-hover:text-purple-300 transition-colors">1/2/45</span>
        </div>
        <div class="h-6 w-[1px] bg-white/10"></div>
        <div class="flex flex-col gap-1">
          <span class="text-neutral-400 uppercase text-[8px]">Action Telegram</span>
          <span class="text-amber-400 font-semibold group-hover:scale-105 transition-transform duration-300">0x01 (Play)</span>
        </div>
      </div>
    </div>

    <!-- Card 5: Smart Track Caching (col-span-1) -->
    <div class="glass-card shadow-glow-card rounded-2xl p-6 flex flex-col justify-between overflow-hidden group hover:border-amber-500/30 hover:shadow-glow-amber/5 relative min-h-[260px]">
      <div class="relative z-10 flex flex-col gap-2">
        <span class="px-2 py-0.5 text-[9px] uppercase font-mono tracking-wider bg-amber-500/10 border border-amber-500/20 text-amber-400 rounded-md w-fit">Resiliency</span>
        <h3 class="text-lg font-semibold mt-1">Smart Buffer Caching</h3>
        <p class="text-xs text-neutral-400 leading-relaxed">
          Zero playback dropouts. Pre-caches streams dynamically, absorbing network spikes and protecting audio streams from brief offline interruptions.
        </p>
      </div>

      <!-- Caching Buffer visual -->
      <div class="mt-4 flex flex-col gap-2 bg-black/20 border border-white/5 rounded-xl p-3 min-h-[80px]">
        <div class="flex justify-between items-center text-[9px] font-mono">
          <span class="text-neutral-400">Buffer Size</span>
          <span class="text-amber-400">30s (100%)</span>
        </div>
        <div class="w-full h-3 rounded-full bg-white/5 overflow-hidden relative">
          <!-- Filled state -->
          <div class="h-full bg-amber-500/80 rounded-full group-hover:bg-amber-400 transition-all duration-700 w-[92%] relative">
            <div class="absolute right-0 top-0 bottom-0 w-4 bg-white/20 animate-pulse"></div>
          </div>
        </div>
        <span class="text-[8px] font-mono text-neutral-400 text-right">92% Cached • 320kbps <abbr title="Advanced Audio Coding">AAC</abbr></span>
      </div>
    </div>

    <!-- Card 6: SnapDog OS Kernel (col-span-2) -->
    <div class="glass-card shadow-glow-card rounded-2xl p-6 md:col-span-2 flex flex-col justify-between overflow-hidden group hover:border-amber-500/30 hover:shadow-glow-amber/5 relative min-h-[280px]">
      <div class="absolute inset-0 bg-gradient-to-tr from-amber-500/0 via-amber-500/0 to-amber-500/[0.02] pointer-events-none"></div>
      
      <div class="relative z-10 flex flex-col gap-2 max-w-md">
        <span class="px-2 py-0.5 text-[9px] uppercase font-mono tracking-wider bg-orange-500/10 border border-orange-500/20 text-orange-400 rounded-md w-fit">Operating System</span>
        <h3 class="text-lg font-semibold mt-1">Real-time Embedded <abbr title="Operating System">OS</abbr></h3>
        <p class="text-xs text-neutral-400 leading-relaxed">
          SnapDog <abbr title="Operating System">OS</abbr> is a tailored, read-only Linux kernel designed for low-jitter audio thread execution. Fast cold boots under 4 seconds, direct hardware access, and absolute stability.
        </p>
      </div>

      <!-- Linux pseudo-terminal console -->
      <div class="mt-4 font-mono text-[9px] bg-stone-950 border border-white/5 rounded-xl p-3 flex flex-col gap-1 min-h-[100px] overflow-hidden select-text text-neutral-300">
        <div class="flex justify-between items-center text-[8px] text-neutral-400 border-b border-white/5 pb-1 mb-1">
          <span>kernel: v6.6.21-rt-snapdog</span>
          <span>uptime: 42d 12h</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-neutral-400">[ 0.0451 ]</span>
          <span>Pinning audio handler thread to <span class="text-amber-400 font-bold"><abbr title="Central Processing Unit">CPU</abbr> Core 3</span></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-neutral-400">[ 0.0821 ]</span>
          <span>Set scheduling policy: <span class="text-green-400">SCHED_FIFO</span> (Priority 99)</span>
        </div>
        <div class="flex items-center gap-2 opacity-80">
          <span class="text-neutral-400">[ 0.1205 ]</span>
          <span>Audio buffer pre-allocated: <span class="text-amber-400">65536 bytes <abbr title="Advanced Linux Sound Architecture">ALSA</abbr> ringbuffer</span></span>
        </div>
        <div class="flex items-center gap-2 opacity-50 group-hover:opacity-100 transition-opacity">
          <span class="text-neutral-400">[ 0.1982 ]</span>
          <span><abbr title="Advanced Linux Sound Architecture">ALSA</abbr>: Initialized SnapDog-HiFi <abbr title="Digital-to-Analog Converter">DAC</abbr> [PCM5122]</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-flow-green {
    stroke-dasharray: 6 6;
    animation: flow 1.5s linear infinite;
  }
  .animate-flow-amber {
    stroke-dasharray: 6 6;
    animation: flow 1.5s linear infinite;
  }
  .animate-flow-sky {
    stroke-dasharray: 6 6;
    animation: flow 1.5s linear infinite;
  }

  @keyframes flow {
    to {
      stroke-dashoffset: -12;
    }
  }
</style>
