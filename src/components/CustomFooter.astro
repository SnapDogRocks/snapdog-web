---
// src/components/CustomFooter.astro
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Footer.astro';
---

<div class="starlight-footer-wrapper">
  <!-- Render the default Starlight footer (pagination, edit page, last updated) -->
  <Default {...Astro.props} />

  <!-- Divider and Landing-page-style Custom Footer -->
  <footer class="custom-portal-footer">
    <div class="footer-left">
      <p class="copyright">© 2026 Fabian Schmieder</p>
      <a href="/docs/license" class="cc-badge-link" aria-label="Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International License">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 165 30" class="cc-svg-badge">
          <!-- CC (Creative Commons) -->
          <circle cx="10" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
          <path d="M 9.5,12.5 C 8,12.5 7,13.5 7,15 C 7,16.5 8,17.5 9.5,17.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          <path d="M 13,12.5 C 11.5,12.5 10.5,13.5 10.5,15 C 10.5,16.5 11.5,17.5 13,17.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          
          <!-- BY (Attribution) -->
          <circle cx="28" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
          <circle cx="28" cy="11.8" r="1.5" fill="currentColor" />
          <path d="M 28,13.8 C 26.8,13.8 26.3,14.8 26.3,16.3 L 27.1,16.3 L 27.1,20 L 28,20 L 28,18.2 L 28,20 L 28.9,20 L 28.9,16.3 L 29.7,16.3 C 29.7,14.8 29.2,13.8 28,13.8 Z" fill="currentColor" />

          <!-- NC (Non-Commercial) -->
          <circle cx="46" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
          <line x1="46" y1="10.5" x2="46" y2="19.5" stroke="currentColor" stroke-width="1" />
          <path d="M 47.5,12.8 C 47.5,11.8 44.5,11.8 44.5,13.2 C 44.5,15 47.5,14.5 47.5,16.2 C 47.5,18 44.5,18 44.5,17.2" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
          <line x1="43" y1="17.5" x2="49" y2="12.5" stroke="currentColor" stroke-width="1.2" />

          <!-- SA (Share-Alike) -->
          <circle cx="64" cy="15" r="7" fill="none" stroke="currentColor" stroke-width="1.2" />
          <path d="M 67.2,14.2 C 67.2,12.2 65.5,10.5 63.5,10.5 C 61,10.5 59.8,12.8 59.8,15 C 59.8,17.2 61,19.5 63.5,19.5 C 65.5,19.5 67.2,17.8 67.2,15.8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
          <polyline points="65.5,17.2 67.2,15.8 68.9,17.2" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />

          <!-- Text -->
          <text x="78" y="18" fill="currentColor" font-family="monospace" font-size="8.5" font-weight="bold" letter-spacing="0.5">BY-NC-SA 4.0</text>
        </svg>
      </a>
    </div>
    <div class="footer-links">
      <a href="/docs/introduction" class="footer-link" aria-label="Read SnapDog documentation">Docs</a>
      <a href="https://github.com/SnapDogRocks/snapdog-os" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="View SnapDog GitHub repository">GitHub</a>
      <a href="/docs/snapdog-os" class="footer-link" aria-label="Read SnapDog OS installation guide and get download links">SnapDog OS</a>
      <a href="/docs/license" class="footer-link" aria-label="Read SnapDog licensing information">License</a>
      <a href="/imprint" class="footer-link" aria-label="Read SnapDog imprint">Imprint</a>
      <a href="/privacy" class="footer-link" aria-label="Read SnapDog privacy policy">Privacy</a>
    </div>
  </footer>
</div>

<style>
  .starlight-footer-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-top: 3rem;
  }
  .custom-portal-footer {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2rem;
    padding-bottom: 2rem;
    margin-top: 2rem;
    border-top: 1px solid var(--sl-color-hairline, rgba(255, 255, 255, 0.1));
    font-size: var(--sl-text-xs, 0.75rem);
    color: var(--sl-color-gray-3, #a3a3a3);
  }
  .footer-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }
  .copyright {
    margin: 0;
  }
  .cc-badge-link {
    display: inline-flex;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }
  .cc-badge-link:hover {
    opacity: 1;
  }
  .cc-svg-badge {
    width: 145px;
    height: 26px;
    color: var(--sl-color-gray-4, #737373);
    transition: color 0.3s ease;
  }
  .cc-svg-badge:hover {
    color: var(--sl-color-accent, #fbbf24);
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }
  .footer-link {
    color: var(--sl-color-gray-3, #a3a3a3);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: var(--sl-color-text-accent, #fbbf24);
  }

  @media (min-width: 50rem) {
    .custom-portal-footer {
      flex-direction: row;
      gap: 2rem;
    }
    .footer-left {
      flex-direction: row;
      text-align: left;
    }
  }
</style>
