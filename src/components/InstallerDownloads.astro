---
import release from '../data/snapdog-os-installer-release.json';

const downloadBase = `https://github.com/SnapDogRocks/snapdog-os-installer/releases/download/${release.tag}`;
const assetUrl = (name: string) => `${downloadBase}/${name}`;
---

<div class="installer-release">
  <p>
    The current release is <a href={release.releaseUrl}>SnapDog OS Installer v{release.version}</a>.
  </p>
</div>

<p>Download the installer for your computer:</p>

<table>
  <thead><tr><th>Platform</th><th>Installer</th></tr></thead>
  <tbody>
    <tr><td><strong>macOS</strong> (Apple silicon and Intel)</td><td><a href={assetUrl(release.assets.macosUniversalDmg)}>Universal DMG</a></td></tr>
    <tr><td><strong>Windows x64</strong></td><td><a href={assetUrl(release.assets.windowsX64Exe)}>EXE</a></td></tr>
    <tr><td><strong>Windows ARM64</strong></td><td><a href={assetUrl(release.assets.windowsArm64Exe)}>EXE</a></td></tr>
    <tr><td><strong>Linux x64</strong></td><td><a href={assetUrl(release.assets.linuxX64AppImage)}>AppImage</a></td></tr>
    <tr><td><strong>Linux ARM64</strong></td><td><a href={assetUrl(release.assets.linuxArm64AppImage)}>AppImage</a></td></tr>
  </tbody>
</table>

<p><a href={release.releaseUrl}>View all release assets, checksums, and build provenance</a>.</p>

<style>
  .installer-release {
    margin-block: 1rem;
    padding: 0.85rem 1rem;
    border-inline-start: 0.25rem solid var(--sl-color-blue);
    border-radius: 0.25rem;
    background: var(--sl-color-blue-low);
  }
  .installer-release p { margin: 0; }
</style>
