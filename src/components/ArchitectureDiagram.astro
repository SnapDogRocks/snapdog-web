---
// ArchitectureDiagram.astro
// Premium, interactive SVG systems architecture diagram for SnapDog docs
---

<div class="architecture-diagram-container my-8 w-full glass-card rounded-2xl border border-neutral-200/10 dark:border-white/10 p-4 sm:p-6 md:p-8 relative overflow-hidden flex flex-col items-center">
  <div class="absolute inset-0 bg-radial from-amber-500/[0.02] via-transparent to-transparent pointer-events-none"></div>

  <!-- Zoom Button -->
  <button
    id="zoom-btn"
    class="absolute top-4 right-4 z-30 p-2.5 rounded-xl bg-neutral-900/60 hover:bg-neutral-800/80 border border-neutral-200/10 dark:border-white/10 text-neutral-400 hover:text-white transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-amber-500/50 shadow-lg hover:scale-105 active:scale-95"
    title="Zoom to sheet (Fullscreen)"
    aria-label="Zoom to sheet"
  >
    <svg id="expand-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4.5 h-4.5" style="display: block;">
      <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
    </svg>
    <svg id="collapse-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4.5 h-4.5" style="display: none;">
      <path d="M4 14h6v6M20 10h-6V4M14 10l7-7M10 14l-7 7"/>
    </svg>
  </button>

  <!-- SVG Board -->
  <div class="w-full max-w-3xl aspect-[8/6] relative">
    <svg
      id="system-arch-svg"
      viewBox="0 0 800 600"
      class="w-full h-full overflow-visible select-none"
    >
      <defs>
        <!-- Amber flow gradient -->
        <linearGradient id="flow-amber" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.2"></stop>
          <stop offset="50%" stop-color="#fbbf24" stop-opacity="1"></stop>
          <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.2"></stop>
        </linearGradient>
        
        <!-- Audio stream thick output gradient -->
        <linearGradient id="flow-audio" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.8"></stop>
          <stop offset="100%" stop-color="#d97706" stop-opacity="0.2"></stop>
        </linearGradient>

        <!-- Drop shadow glows -->
        <filter id="glow-amber-filter" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="4" result="blur"></feGaussianBlur>
          <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
        </filter>
      </defs>

      <!-- Background Grid Guides (Subtle) -->
      <g stroke="currentColor" class="text-neutral-200/5 dark:text-white/5" stroke-width="1">
        <line x1="0" y1="100" x2="800" y2="100"></line>
        <line x1="0" y1="200" x2="800" y2="200"></line>
        <line x1="0" y1="300" x2="800" y2="300"></line>
        <line x1="0" y1="400" x2="800" y2="400"></line>
        <line x1="0" y1="500" x2="800" y2="500"></line>
        <line x1="200" y1="0" x2="200" y2="600"></line>
        <line x1="400" y1="0" x2="400" y2="600"></line>
        <line x1="600" y1="0" x2="600" y2="600"></line>
      </g>

      <!-- ==================== LAYER 1: INPUT SOURCES (LEFT) ==================== -->
      <!-- Group Title -->
      <text x="30" y="40" fill="currentColor" class="text-neutral-500 font-mono text-[10px] tracking-wider uppercase font-semibold">Input Feeds</text>
      
      <!-- Source 1: AirPlay 2 -->
      <g id="src-airplay" class="src-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect AirPlay 2 input source">
        <rect x="25" y="60" width="140" height="46" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/50"></rect>
        <circle cx="50" cy="83" r="12" fill="#171717" stroke="#fbbf24" stroke-width="1.5" class="status-led"></circle>
        <!-- AirPlay Icon -->
        <g transform="translate(50, 83) scale(0.8)" class="text-amber-400">
          <rect x="-8" y="-9" width="16" height="11" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.2"></rect>
          <polygon points="-4,6 4,6 0,2" fill="currentColor"></polygon>
        </g>
        <text x="72" y="81" fill="currentColor" class="text-neutral-200 font-sans text-xs font-semibold">AirPlay 2</text>
        <text x="72" y="93" fill="currentColor" class="text-neutral-500 font-mono text-[9px]">Local Apple Feed</text>
      </g>

      <!-- Source 2: Spotify Connect -->
      <g id="src-spotify" class="src-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect Spotify Connect input source">
        <rect x="25" y="126" width="140" height="46" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/50"></rect>
        <circle cx="50" cy="149" r="12" fill="#171717" stroke="#22c55e" stroke-width="1.5" class="status-led"></circle>
        <!-- Spotify Icon -->
        <g transform="translate(50, 149) scale(0.8)" class="text-green-500">
          <circle cx="0" cy="0" r="7" fill="none" stroke="currentColor" stroke-width="1.2"></circle>
          <path d="M -3.5,-1.5 Q 0,-3 3.5,-1.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
          <path d="M -2.5,1 Q 0,-0.5 2.5,1" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"></path>
        </g>
        <text x="72" y="147" fill="currentColor" class="text-neutral-200 font-sans text-xs font-semibold">Spotify Connect</text>
        <text x="72" y="159" fill="currentColor" class="text-neutral-500 font-mono text-[9px]">via librespot</text>
      </g>

      <!-- Source 3: Subsonic / Navidrome -->
      <g id="src-subsonic" class="src-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect Subsonic media server source">
        <rect x="25" y="192" width="140" height="46" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/50"></rect>
        <circle cx="50" cy="215" r="12" fill="#171717" stroke="#a855f7" stroke-width="1.5" class="status-led"></circle>
        <!-- Cloud / Server Icon -->
        <g transform="translate(50, 215) scale(0.8)" class="text-purple-400">
          <path d="M-6,3 A3.5,3.5 0 0,1 -4,-3.5 A4.5,4.5 0 0,1 4,-2 A3.5,3.5 0 0,1 6,3 Z" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"></path>
        </g>
        <text x="72" y="213" fill="currentColor" class="text-neutral-200 font-sans text-xs font-semibold">Subsonic Server</text>
        <text x="72" y="225" fill="currentColor" class="text-neutral-500 font-mono text-[9px]">Navidrome Library</text>
      </g>

      <!-- Source 4: Internet Radio -->
      <g id="src-radio" class="src-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect Internet Radio source">
        <rect x="25" y="258" width="140" height="46" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/50"></rect>
        <circle cx="50" cy="281" r="12" fill="#171717" stroke="#0ea5e9" stroke-width="1.5" class="status-led"></circle>
        <!-- Signal / Radio Tower Icon -->
        <g transform="translate(50, 281) scale(0.8)" class="text-sky-400">
          <circle cx="0" cy="2" r="2" fill="currentColor"></circle>
          <path d="M -3,-1 A 4,4 0 0,1 3,-1" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"></path>
          <path d="M -5,-4 A 7,7 0 0,1 5,-4" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"></path>
        </g>
        <text x="72" y="279" fill="currentColor" class="text-neutral-200 font-sans text-xs font-semibold">Internet Radio</text>
        <text x="72" y="291" fill="currentColor" class="text-neutral-500 font-mono text-[9px]">Direct ICY Streams</text>
      </g>

      <!-- ==================== LAYER 2: ZONE ENGINE (TOP CENTER) ==================== -->
      <!-- Engine Outer Container -->
      <g id="engine-container">
        <rect x="210" y="20" width="380" height="230" rx="12" fill="rgba(255,255,255,0.01)" stroke="rgba(255,255,255,0.06)" stroke-width="1.5"></rect>
        <rect x="225" y="30" width="10" height="10" rx="2" fill="#fbbf24" class="animate-pulse"></rect>
        <text x="242" y="39" fill="currentColor" class="text-neutral-200 font-sans text-xs font-bold uppercase tracking-wider">Zone Engine (Tokio Tasks)</text>
      </g>

      <!-- ZonePlayer 1 (Living Room) -->
      <g id="player-1" class="player-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect ZonePlayer 1">
        <rect x="230" y="60" width="100" height="170" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/40"></rect>
        <text x="240" y="76" fill="currentColor" class="text-neutral-200 font-sans text-[10px] font-bold">ZonePlayer 1</text>
        <text x="240" y="87" fill="#fbbf24" class="font-mono text-[8px] uppercase tracking-wide">Living Room</text>

        <!-- Pipeline Stack inside Player 1 -->
        <!-- RCV Block -->
        <g class="pipe-stage" id="p1-rcv">
          <rect x="240" y="98" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="280" y="112" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ RECEIVER ]</text>
        </g>
        <!-- DEC Block -->
        <g class="pipe-stage" id="p1-dec">
          <rect x="240" y="128" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="280" y="142" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ DECODER ]</text>
        </g>
        <!-- DSP Block -->
        <g class="pipe-stage" id="p1-dsp">
          <rect x="240" y="158" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="280" y="172" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ DSP / EQ ]</text>
        </g>
        <!-- WTR Block -->
        <g class="pipe-stage" id="p1-wtr">
          <rect x="240" y="188" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="280" y="202" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ WRITER ]</text>
        </g>
      </g>

      <!-- ZonePlayer 2 (Kitchen) -->
      <g id="player-2" class="player-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect ZonePlayer 2">
        <rect x="350" y="60" width="100" height="170" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/40"></rect>
        <text x="360" y="76" fill="currentColor" class="text-neutral-200 font-sans text-[10px] font-bold">ZonePlayer 2</text>
        <text x="360" y="87" fill="#fbbf24" class="font-mono text-[8px] uppercase tracking-wide">Kitchen</text>

        <!-- Pipeline Stack inside Player 2 -->
        <!-- RCV Block -->
        <g class="pipe-stage" id="p2-rcv">
          <rect x="360" y="98" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="400" y="112" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ RECEIVER ]</text>
        </g>
        <!-- DEC Block -->
        <g class="pipe-stage" id="p2-dec">
          <rect x="360" y="128" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="400" y="142" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ DECODER ]</text>
        </g>
        <!-- DSP Block -->
        <g class="pipe-stage" id="p2-dsp">
          <rect x="360" y="158" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="400" y="172" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ DSP / EQ ]</text>
        </g>
        <!-- WTR Block -->
        <g class="pipe-stage" id="p2-wtr">
          <rect x="360" y="188" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="400" y="202" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ WRITER ]</text>
        </g>
      </g>

      <!-- ZonePlayer N (Patio) -->
      <g id="player-3" class="player-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect ZonePlayer N">
        <rect x="470" y="60" width="100" height="170" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/40"></rect>
        <text x="480" y="76" fill="currentColor" class="text-neutral-200 font-sans text-[10px] font-bold">ZonePlayer N</text>
        <text x="480" y="87" fill="#fbbf24" class="font-mono text-[8px] uppercase tracking-wide">Patio</text>

        <!-- Pipeline Stack inside Player N -->
        <!-- RCV Block -->
        <g class="pipe-stage" id="p3-rcv">
          <rect x="480" y="98" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="520" y="112" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ RECEIVER ]</text>
        </g>
        <!-- DEC Block -->
        <g class="pipe-stage" id="p3-dec">
          <rect x="480" y="128" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="520" y="142" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ DECODER ]</text>
        </g>
        <!-- DSP Block -->
        <g class="pipe-stage" id="p3-dsp">
          <rect x="480" y="158" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="520" y="172" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ DSP / EQ ]</text>
        </g>
        <!-- WTR Block -->
        <g class="pipe-stage" id="p3-wtr">
          <rect x="480" y="188" width="80" height="22" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="520" y="202" text-anchor="middle" fill="currentColor" class="text-neutral-400 font-mono text-[9px]">[ WRITER ]</text>
        </g>
      </g>


      <!-- ==================== LAYER 3: EMBEDDED SNAPCAST SERVER (MIDDLE CENTER) ==================== -->
      <!-- Snapcast Server Outer Box -->
      <g id="snapcast-server" class="cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect Embedded Snapcast Server">
        <rect x="210" y="310" width="380" height="120" rx="12" fill="rgba(255,255,255,0.01)" stroke="rgba(255,255,255,0.06)" stroke-width="1.5" class="transition-all duration-300 hover:fill-white/[0.03] hover:stroke-amber-500/30"></rect>
        <circle cx="230" cy="330" r="5" fill="#10b981" class="animate-pulse"></circle>
        <text x="242" y="334" fill="currentColor" class="text-neutral-200 font-sans text-xs font-bold uppercase tracking-wider">Embedded Snapcast Server</text>

        <!-- Components inside Snapcast Server -->
        <!-- Stream Buffers -->
        <g id="srv-buffers" class="srv-comp">
          <rect x="225" y="350" width="105" height="60" rx="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="277" y="375" text-anchor="middle" fill="currentColor" class="text-neutral-200 font-sans text-[10px] font-bold">Stream Buffers</text>
          <text x="277" y="390" text-anchor="middle" fill="currentColor" class="text-neutral-500 font-mono text-[8px]">(Per-Zone Queues)</text>
        </g>

        <!-- Lossless Encoders -->
        <g id="srv-encoders" class="srv-comp">
          <rect x="347" y="350" width="105" height="60" rx="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="400" y="375" text-anchor="middle" fill="currentColor" class="text-neutral-200 font-sans text-[10px] font-bold">FLAC / F32LZ4</text>
          <text x="400" y="390" text-anchor="middle" fill="currentColor" class="text-neutral-500 font-mono text-[8px]">Lossless Encoders</text>
        </g>

        <!-- Group Sync Coordinator -->
        <g id="srv-sync" class="srv-comp">
          <rect x="470" y="350" width="105" height="60" rx="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.05)" stroke-width="1"></rect>
          <text x="522" y="375" text-anchor="middle" fill="currentColor" class="text-neutral-200 font-sans text-[10px] font-bold">Latency Sync</text>
          <text x="522" y="390" text-anchor="middle" fill="currentColor" class="text-neutral-500 font-mono text-[8px]">Group Coordinator</text>
        </g>
      </g>


      <!-- ==================== LAYER 4: SMART HOME & CONTROL BRIDGES (RIGHT) ==================== -->
      <!-- Group Title -->
      <text x="770" y="40" text-anchor="end" fill="currentColor" class="text-neutral-500 font-mono text-[10px] tracking-wider uppercase font-semibold">Bridges & APIs</text>

      <!-- Bridge 1: REST API & WebUI -->
      <g id="bridge-rest" class="bridge-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect REST API and Web UI Bridge">
        <rect x="635" y="60" width="140" height="46" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/50"></rect>
        <circle cx="750" cy="83" r="12" fill="#171717" stroke="#38bdf8" stroke-width="1.5" class="status-led"></circle>
        <!-- Code / Web Icon -->
        <g transform="translate(750, 83) scale(0.8)" class="text-sky-400">
          <path d="M-6,-3 L-2,1 L-6,5 M6,-3 L2,1 L6,5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </g>
        <text x="728" y="81" text-anchor="end" fill="currentColor" class="text-neutral-200 font-sans text-xs font-semibold">REST API & WebUI</text>
        <text x="728" y="93" text-anchor="end" fill="currentColor" class="text-neutral-500 font-mono text-[9px]">Axum Engine</text>
      </g>

      <!-- Bridge 2: WebSocket API -->
      <g id="bridge-ws" class="bridge-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect WebSocket API Sync Bridge">
        <rect x="635" y="126" width="140" height="46" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/50"></rect>
        <circle cx="750" cy="149" r="12" fill="#171717" stroke="#0ea5e9" stroke-width="1.5" class="status-led"></circle>
        <!-- Sync Icon -->
        <g transform="translate(750, 149) scale(0.8)" class="text-sky-500">
          <path d="M-5,-1 A5,5 0 0,1 5,-1 M5,2 A5,5 0 0,1 -5,2" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
          <polygon points="5,-4 8,-1 5,2" fill="currentColor" transform="scale(0.8) translate(3, -2)"></polygon>
        </g>
        <text x="728" y="147" text-anchor="end" fill="currentColor" class="text-neutral-200 font-sans text-xs font-semibold">WebSocket API</text>
        <text x="728" y="159" text-anchor="end" fill="currentColor" class="text-neutral-500 font-mono text-[9px]">Real-Time Sync</text>
      </g>

      <!-- Bridge 3: D-Bus (MPRIS2) -->
      <g id="bridge-dbus" class="bridge-node cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Inspect D-Bus MPRIS2 API Bridge">
        <rect x="635" y="192" width="140" height="46" rx="8" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="transition-all duration-300 hover:fill-white/[0.04] hover:stroke-amber-500/50"></rect>
        <circle cx="750" cy="215" r="12" fill="#171717" stroke="#a855f7" stroke-width="1.5" class="status-led"></circle>
        <!-- DBus topology node icon -->
        <g transform="translate(750, 215) scale(0.8)" class="text-purple-400">
          <circle cx="-4" cy="-3" r="2" fill="none" stroke="currentColor" stroke-width="1.2"></circle>
          <circle cx="4" cy="-3" r="2" fill="none" stroke="currentColor" stroke-width="1.2"></circle>
          <circle cx="0" cy="4" r="2" fill="none" stroke="currentColor" stroke-width="1.2"></circle>
          <line x1="-3" y1="-1" x2="-1" y2="2" stroke="currentColor" stroke-width="1"></line>
          <line x1="3" y1="-1" x2="1" y2="2" stroke="currentColor" stroke-width="1"></line>
        </g>
        <text x="728" y="213" text-anchor="end" fill="currentColor" class="text-neutral-200 font-sans text-xs font-semibold">D-Bus (MPRIS2)</text>
        <text x="728" y="225" text-anchor="end" fill="currentColor" class="text-neutral-500 font-mono text-[9px]">Linux Desktop Control</text>
      </g>

      <!-- Bridge 4: MQTT Bridge -->
