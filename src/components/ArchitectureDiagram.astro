</style>

<script>
  // Interactive metadata console data
  const metadata = {
    "src-airplay": {
      title: "AirPlay 2 Receiver Source",
      text: "Module: receiver/airplay.rs\n- Listens on TCP sockets for iOS/macOS audio mirroring streams.\n- Instantiates a background loop that decodes raw audio packets.\n- Writes decoded samples directly into the ZonePlayer stream queue, overriding any lower priority play states."
    },
    "src-spotify": {
      title: "Spotify Connect Source",
      text: "Module: receiver/spotify.rs\n- Embedded librespot backend.\n- Acts as an official Spotify Connect device on the local network.\n- Pulls audio streams directly from Spotify CDN servers and passes raw PCM samples to the target ZonePlayer task."
    },
    "src-subsonic": {
      title: "Subsonic / Navidrome Source",
      text: "Module: subsonic/mod.rs\n- Streams audio library directories over HTTP.\n- ZonePlayer decodes these streams dynamically via the symphonia crate.\n- Pre-caches audio buffers to assure seamless, gapless playback on transition nodes."
    },
    "src-radio": {
      title: "Internet Radio Source",
      text: "Module: audio/icy.rs\n- Direct stream URL player.\n- Fetches HTTP web radio streams and reads inline ICY metadata streams (extracting song titles/artists dynamically).\n- Feeds compressed audio channels to the symphonia decoder module."
    },
    "player-1": {
      title: "ZonePlayer 1 - Living Room (Tokio Task)",
      text: "Module: player/runner.rs\n- Independent async loop running as a tokio task.\n- Decodes inputs, applies biquad EQ parametric filters, and handles speaker cabinet correction profiles.\n- Streams processed output to the Snapcast Server buffer."
    },
    "player-2": {
      title: "ZonePlayer 2 - Kitchen (Tokio Task)",
      text: "Module: player/runner.rs\n- Dedicated audio runner. Applies parametric volume mixing and DSP correction to Kitchen speakers.\n- Resamples input streams to matching target sample rates (44.1kHz or 48kHz)."
    },
    "player-3": {
      title: "ZonePlayer N - Patio Zone (Tokio Task)",
      text: "Module: player/runner.rs\n- Handles the outdoor speaker zone. Integrates specific latency offset values (+45ms) to offset geographical echo when synchronized."
    },
    "snapcast-server": {
      title: "Embedded Snapcast Server",
      text: "Module: snapcast/embedded.rs & mod.rs\n- Central multi-room distribution server.\n- Aggregates stream buffers, encodes raw float PCM to FLAC or F32LZ4, and distributes packets to room snapclient sinks over TCP ports (1704)."
    },
    "bridge-rest": {
      title: "REST API & WebUI",
      text: "Module: api/routes/\n- Powered by Axum framework.\n- Handles client player control requests (play/pause, seek, volume, EQ changes).\n- Integrates OpenAPI auto-generated spec sandbox (Scalar UI)."
    },
    "bridge-ws": {
      title: "WebSocket State Sync API",
      text: "Module: api/routes/websocket\n- Broadcasts playback state mutations, volume changes, metadata objects, and client presence status to connected web frontends instantaneously."
    },
    "bridge-dbus": {
      title: "D-Bus API (MPRIS2 Interface)",
      text: "Module: dbus/mod.rs\n- Registers individual zones as D-Bus objects.\n- Implements standard MPRIS2 interfaces allowing system-level integration (e.g. control widgets, desktop keyboard keys, playerctl commands)."
    },
    "bridge-mqtt": {
      title: "MQTT Smart Home Bridge",
      text: "Module: mqtt/mod.rs\n- Subscribes to command topics and publishes telemetry status updates.\n- Implements zero-configuration Home Assistant integration for smart home dashboards."
    },
    "bridge-knx": {
      title: "KNX IP Multicast Bridge",
      text: "Module: knx/mod.rs\n- Communicates over local physical KNX smart building buses.\n- Maps bus telegrams (group addresses) to player commands, allowing standard light switches to toggle audio playback."
    },
    "sink-room1": {
      title: "snapclient - Living Room",
      text: "Binary: snapdog-client / snapclients\n- Headless receiver connected to the server over TCP socket stream.\n- Receives compressed FLAC packets, decodes, and outputs to target sound card driver."
    },
    "sink-room2": {
      title: "snapclient - Kitchen",
      text: "Binary: snapdog-client\n- head-end audio sink board. Operates a hardware volume mixer via ALSA controls to prevent digital resolution clipping."
    },
    "sink-room3": {
      title: "snapclient - Patio Zone",
      text: "Binary: snapdog-client\n- हेड-एंड audio sink. Synchronizes stream playback clock locally based on server sync calculations to achieve zero echo."
    }
  };

  const flowMappings = {
    "src-airplay": ["flow-airplay-p1", "flow-p1-srv", "flow-srv-room1"],
    "src-spotify": ["flow-spotify-p2", "flow-p2-srv", "flow-srv-room2"],
    "src-subsonic": ["flow-subsonic-p3", "flow-p3-srv", "flow-srv-room3"],
    "src-radio": ["flow-radio-p3", "flow-p3-srv", "flow-srv-room3"],
    "player-1": ["flow-airplay-p1", "flow-p1-srv", "flow-srv-room1"],
    "player-2": ["flow-spotify-p2", "flow-p2-srv", "flow-srv-room2"],
    "player-3": ["flow-subsonic-p3", "flow-radio-p3", "flow-p3-srv", "flow-srv-room3"],
    "snapcast-server": [
      "flow-p1-srv", "flow-p2-srv", "flow-p3-srv",
      "flow-srv-room1", "flow-srv-room2", "flow-srv-room3"
    ],
    "sink-room1": ["flow-airplay-p1", "flow-p1-srv", "flow-srv-room1"],
    "sink-room2": ["flow-spotify-p2", "flow-p2-srv", "flow-srv-room2"],
    "sink-room3": ["flow-subsonic-p3", "flow-radio-p3", "flow-p3-srv", "flow-srv-room3"]
  };

  // Wrap layout logic inside a transition-safe function
  const init = () => {
    const svg = document.getElementById("system-arch-svg");
    const consoleOutput = document.getElementById("console-output");
    const container = document.querySelector(".architecture-diagram-container");

    if (!svg || !consoleOutput || !container) return;

    // Avoid duplicate initialization if script runs multiple times
    if (container.dataset.initialized === "true") return;
    container.dataset.initialized = "true";

    // Add event listeners on nodes
    Object.keys(metadata).forEach(nodeId => {
      const node = svg.getElementById(nodeId);
      if (node) {
        // Hover start
        node.addEventListener("mouseenter", () => {
          // Update console
          const data = metadata[nodeId];
          consoleOutput.innerHTML = `<strong>${data.title}</strong>\n${data.text}`.replace(/\n/g, "<br/>");
          
          // Trigger related flow lines glow
          const activeFlows = flowMappings[nodeId] || [];
          activeFlows.forEach(flowId => {
            const line = svg.getElementById(flowId);
            if (line) {
              line.classList.add("flow-line-active");
            }
          });
        });

        // Hover end
        node.addEventListener("mouseleave", () => {
          // Reset console
          consoleOutput.innerHTML = "Hover over any component block in the diagram to inspect its real-time telemetry parameters, active Rust crates, and internal audio routing pipeline configurations.";
          
          // Clear active flow lines
          const activeFlows = flowMappings[nodeId] || [];
          activeFlows.forEach(flowId => {
            const line = svg.getElementById(flowId);
            if (line) {
              line.classList.remove("flow-line-active");
            }
          });
        });
      }
    });

    // Zoom to Sheet Fullscreen Toggle Logic
    const zoomBtn = document.getElementById("zoom-btn");
    const expandIcon = document.getElementById("expand-icon") as HTMLElement;
    const collapseIcon = document.getElementById("collapse-icon") as HTMLElement;

    if (zoomBtn && expandIcon && collapseIcon) {
      // Set initial styles explicitly to prevent build/CSS reset overlaps
      expandIcon.style.display = "block";
      collapseIcon.style.display = "none";

      const toggleFullscreen = () => {
        const isFullscreen = container.classList.toggle("fullscreen-active");
        if (isFullscreen) {
          expandIcon.style.display = "none";
          collapseIcon.style.display = "block";
          document.body.style.overflow = "hidden";
        } else {
          expandIcon.style.display = "block";
          collapseIcon.style.display = "none";
          document.body.style.overflow = "";
        }
      };

      zoomBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleFullscreen();
      });

      // Light dismiss: Close when clicking empty space on the backdrop/container itself
      container.addEventListener("click", (e) => {
        if (container.classList.contains("fullscreen-active") && e.target === container) {
          toggleFullscreen();
        }
      });

      // Close on Escape key (cleaning up any registered handlers to avoid memory leaks)
      if (window["__archEscHandler"]) {
        document.removeEventListener("keydown", window["__archEscHandler"]);
      }
      
      const escHandler = (e) => {
        if (e.key === "Escape" && container.classList.contains("fullscreen-active")) {
          toggleFullscreen();
        }
      };
      
      window["__archEscHandler"] = escHandler;
      document.addEventListener("keydown", escHandler);
    }

    // IntersectionObserver to pause all SVG animations when offscreen
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Resume animations
          svg.style.opacity = "1";
          svg.querySelectorAll("animate, animateMotion").forEach((anim) => {
            try {
              (anim as any).beginElement();
            } catch (e) {}
          });
        } else {
          // Pause animations (saves CPU)
          svg.style.opacity = "0.7";
          svg.querySelectorAll("animate, animateMotion").forEach((anim) => {
            try {
              (anim as any).endElement();
            } catch (e) {}
          });
        }
      });
    }, { threshold: 0.1 });
    
    observer.observe(container);
  };

  // Run on initial page load
  init();

  // Run on page transition (if Astro view transitions are used in Starlight)
  document.addEventListener("astro:page-load", init);
</script>
