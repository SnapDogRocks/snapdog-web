---
// Interactive Audio Routing Visualizer
---

<section class="w-full max-w-4xl px-0 sm:px-4 py-16 flex flex-col gap-8 text-center items-center">
  <div id="architecture" class="flex flex-col gap-3 max-w-xl scroll-mt-16">
    <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight text-white font-display">
      Real-Time <span class="text-amber-400 glow-amber">Routing</span> & Sync
    </h2>
    <p class="text-sm text-neutral-400">
      Click active sources on the left to change input routing protocols, or click speaker zones on the right to toggle room sync states.
    </p>
  </div>

  <!-- Visualizer Board -->
  <div class="w-full glass-card shadow-glow-card rounded-2xl p-4 sm:p-6 md:p-10 relative overflow-hidden flex flex-col items-center justify-center">
    <div class="absolute inset-0 bg-radial from-amber-500/[0.01] via-transparent to-transparent pointer-events-none"></div>

    <div class="w-full max-w-2xl aspect-[2/1] relative">
      <svg
        id="routing-svg"
        viewBox="0 0 600 300"
        class="w-full h-full overflow-visible select-none"
      >
        <!-- Grids / Layout Guidelines -->
        <g stroke="rgba(255,255,255,0.02)" stroke-width="1">
          <line x1="0" y1="75" x2="600" y2="75"></line>
          <line x1="0" y1="150" x2="600" y2="150"></line>
          <line x1="0" y1="225" x2="600" y2="225"></line>
          <line x1="150" y1="0" x2="150" y2="300"></line>
          <line x1="300" y1="0" x2="300" y2="300"></line>
          <line x1="450" y1="0" x2="450" y2="300"></line>
        </g>

        <!-- Dynamic Paths (Flowing streams) -->
        <!-- Source -> Server Paths -->
        <path
          id="path-src-airplay"
          d="M 170,50 C 210,50 220,145 250,145"
          fill="none"
          stroke="rgba(255,255,255,0.03)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="3 3"
        ></path>
        <path
          id="path-src-spotify"
          d="M 170,110 C 210,110 220,145 250,145"
          fill="none"
          stroke="rgba(255,255,255,0.03)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="3 3"
        ></path>
        <path
          id="path-src-radio"
          d="M 170,170 C 210,170 220,145 250,145"
          fill="none"
          stroke="rgba(255,255,255,0.03)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="3 3"
        ></path>
        <path
          id="path-src-subsonic"
          d="M 170,230 C 210,230 220,145 250,145"
          fill="none"
          stroke="rgba(255,255,255,0.03)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="3 3"
        ></path>

        <!-- Integration Wires (Control Connections) -->
        <!-- REST API -> Core -->
        <path d="M 220,22 L 270,110" fill="none" stroke="rgba(56, 189, 248, 0.15)" stroke-width="1" stroke-dasharray="2 3"></path>
        <!-- D-Bus -> Core -->
        <path d="M 380,22 L 330,110" fill="none" stroke="rgba(192, 132, 252, 0.15)" stroke-width="1" stroke-dasharray="2 3"></path>
        <!-- MQTT -> Core -->
        <path d="M 220,268 L 270,180" fill="none" stroke="rgba(251, 113, 133, 0.15)" stroke-width="1" stroke-dasharray="2 3"></path>
        <!-- KNX -> Core -->
        <path d="M 380,268 L 330,180" fill="none" stroke="rgba(45, 212, 191, 0.15)" stroke-width="1" stroke-dasharray="2 3"></path>

        <!-- Bidirectional Control Packets (Animate from time to time) -->
        <!-- REST API packets (Blue) -->
        <circle r="2" fill="#38bdf8" opacity="0">
          <animateMotion dur="6s" repeatCount="indefinite" path="M 220,22 L 270,110" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="6s" repeatCount="indefinite" />
        </circle>
        <circle r="2" fill="#38bdf8" opacity="0">
          <animateMotion dur="6s" begin="3s" repeatCount="indefinite" path="M 270,110 L 220,22" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="6s" begin="3s" repeatCount="indefinite" />
        </circle>

        <!-- D-Bus packets (Purple) -->
        <circle r="2" fill="#c084fc" opacity="0">
          <animateMotion dur="7s" begin="1s" repeatCount="indefinite" path="M 380,22 L 330,110" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="7s" begin="1s" repeatCount="indefinite" />
        </circle>
        <circle r="2" fill="#c084fc" opacity="0">
          <animateMotion dur="7s" begin="4.5s" repeatCount="indefinite" path="M 330,110 L 380,22" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="7s" begin="4.5s" repeatCount="indefinite" />
        </circle>

        <!-- MQTT packets (Pink) -->
        <circle r="2" fill="#fb7185" opacity="0">
          <animateMotion dur="5.5s" begin="2s" repeatCount="indefinite" path="M 220,268 L 270,180" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="5.5s" begin="2s" repeatCount="indefinite" />
        </circle>
        <circle r="2" fill="#fb7185" opacity="0">
          <animateMotion dur="5.5s" begin="4.7s" repeatCount="indefinite" path="M 270,180 L 220,268" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="5.5s" begin="4.7s" repeatCount="indefinite" />
        </circle>

        <!-- KNX packets (Teal) -->
        <circle r="2" fill="#2dd4bf" opacity="0">
          <animateMotion dur="6.5s" begin="0.5s" repeatCount="indefinite" path="M 380,268 L 330,180" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="6.5s" begin="0.5s" repeatCount="indefinite" />
        </circle>
        <circle r="2" fill="#2dd4bf" opacity="0">
          <animateMotion dur="6.5s" begin="3.8s" repeatCount="indefinite" path="M 330,180 L 380,268" keyPoints="0;1;1;1;1" keyTimes="0;0.2;0.5;0.8;1" calcMode="linear" />
          <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.02;0.18;0.2;1" dur="6.5s" begin="3.8s" repeatCount="indefinite" />
        </circle>

        <!-- Server -> Room Paths -->
        <path
          id="path-room-1"
          d="M 350,145 C 400,145 420,60 500,60"
          fill="none"
          stroke="url(#grad-amber-flow)"
          stroke-width="2.5"
          stroke-linecap="round"
          class="flowing-line"
        ></path>
        <path
          id="path-room-2"
          d="M 350,145 Q 425,147 500,145"
          fill="none"
          stroke="url(#grad-amber-flow)"
          stroke-width="2.5"
          stroke-linecap="round"
          class="flowing-line"
        ></path>
        <path
          id="path-room-3"
          d="M 350,145 C 400,145 420,230 500,230"
          fill="none"
          stroke="url(#grad-amber-flow)"
          stroke-width="2.5"
          stroke-linecap="round"
          class="flowing-line"
        ></path>

        <!-- Node Gradients -->
        <defs>
          <linearGradient id="grad-amber-flow" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.3"></stop>
            <stop offset="50%" stop-color="#fbbf24" stop-opacity="1"></stop>
            <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.3"></stop>
          </linearGradient>
          <linearGradient id="grad-green-flow" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#22c55e" stop-opacity="0.3"></stop>
            <stop offset="50%" stop-color="#4ade80" stop-opacity="1"></stop>
            <stop offset="100%" stop-color="#22c55e" stop-opacity="0.3"></stop>
          </linearGradient>
          <linearGradient id="grad-blue-flow" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#0ea5e9" stop-opacity="0.3"></stop>
            <stop offset="50%" stop-color="#38bdf8" stop-opacity="1"></stop>
            <stop offset="100%" stop-color="#0ea5e9" stop-opacity="0.3"></stop>
          </linearGradient>
          <linearGradient id="grad-purple-flow" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#a855f7" stop-opacity="0.3"></stop>
            <stop offset="50%" stop-color="#c084fc" stop-opacity="1"></stop>
            <stop offset="100%" stop-color="#a855f7" stop-opacity="0.3"></stop>
          </linearGradient>
        </defs>

        <!-- Source Nodes (Lefthand Side Stack) -->
        <!-- Source 1: AirPlay 2 -->
        <g id="node-src-airplay" class="cursor-pointer group focus:outline-none" role="button" tabindex="0" aria-label="Select AirPlay 2 source" aria-pressed="true">
          <rect x="30" y="34" width="130" height="32" fill="none" pointer-events="all" class="cursor-pointer"></rect>
          <circle cx="50" cy="50" r="16" fill="#0f0f0f" stroke="#f59e0b" stroke-width="1.5" id="src-circle-airplay" class="transition-all duration-300"></circle>
          <circle cx="50" cy="50" r="16" fill="none" stroke="#f59e0b" stroke-width="1.5" id="src-glow-airplay" class="opacity-30 animate-pulse transition-all duration-300"></circle>
          <!-- AirPlay Icon -->
          <g transform="translate(50, 50)" class="text-amber-500" id="src-icon-airplay">
            <rect x="-8" y="-9" width="16" height="11" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.2"></rect>
            <polygon points="-4,6 4,6 0,2" fill="currentColor"></polygon>
          </g>
          <text x="75" y="55" fill="#ffffff" font-family="monospace" font-size="11" font-weight="bold" id="src-text-airplay" class="transition-colors duration-300">AIRPLAY 2</text>
        </g>

        <!-- Source 2: Spotify Connect -->
        <g id="node-src-spotify" class="cursor-pointer group focus:outline-none" role="button" tabindex="0" aria-label="Select Spotify Connect source" aria-pressed="false">
          <rect x="30" y="94" width="130" height="32" fill="none" pointer-events="all" class="cursor-pointer"></rect>
          <circle cx="50" cy="110" r="16" fill="#0f0f0f" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" id="src-circle-spotify" class="transition-all duration-300"></circle>
          <circle cx="50" cy="110" r="16" fill="none" stroke="#22c55e" stroke-width="1.5" id="src-glow-spotify" class="opacity-0 transition-all duration-300"></circle>
          <!-- Spotify Icon -->
          <g transform="translate(50, 110)" class="text-neutral-500" id="src-icon-spotify">
            <circle cx="0" cy="0" r="8" fill="none" stroke="currentColor" stroke-width="1.2"></circle>
            <path d="M -4,-2 Q 0,-4 4,-2" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
            <path d="M -5,1 Q 0,-1 5,1" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"></path>
            <path d="M -4,4 Q 0,2 4,4" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"></path>
          </g>
          <text x="75" y="115" fill="#a3a3a3" font-family="monospace" font-size="11" id="src-text-spotify" class="transition-colors duration-300">SPOTIFY</text>
        </g>

        <!-- Source 3: Internet Radio -->
        <g id="node-src-radio" class="cursor-pointer group focus:outline-none" role="button" tabindex="0" aria-label="Select Internet Radio source" aria-pressed="false">
          <rect x="30" y="154" width="130" height="32" fill="none" pointer-events="all" class="cursor-pointer"></rect>
          <circle cx="50" cy="170" r="16" fill="#0f0f0f" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" id="src-circle-radio" class="transition-all duration-300"></circle>
          <circle cx="50" cy="170" r="16" fill="none" stroke="#0ea5e9" stroke-width="1.5" id="src-glow-radio" class="opacity-0 transition-all duration-300"></circle>
          <!-- Radio Tower Icon -->
          <g transform="translate(50, 170)" class="text-neutral-500" id="src-icon-radio">
            <line x1="0" y1="-8" x2="0" y2="8" stroke="currentColor" stroke-width="1.2"></line>
            <polygon points="-5,8 5,8 0,-1" fill="none" stroke="currentColor" stroke-width="1"></polygon>
            <circle cx="0" cy="-8" r="1.5" fill="currentColor"></circle>
            <path d="M -4,-11 Q 0,-13 4,-11" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"></path>
            <path d="M -6,-14 Q 0,-17 6,-14" fill="none" stroke="currentColor" stroke-width="0.6" stroke-linecap="round"></path>
          </g>
          <text x="75" y="175" fill="#a3a3a3" font-family="monospace" font-size="11" id="src-text-radio" class="transition-colors duration-300">WEB RADIO</text>
        </g>

        <!-- Source 4: Subsonic -->
        <g id="node-src-subsonic" class="cursor-pointer group focus:outline-none" role="button" tabindex="0" aria-label="Select Subsonic source" aria-pressed="false">
          <rect x="30" y="214" width="130" height="32" fill="none" pointer-events="all" class="cursor-pointer"></rect>
          <circle cx="50" cy="230" r="16" fill="#0f0f0f" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" id="src-circle-subsonic" class="transition-all duration-300"></circle>
          <circle cx="50" cy="230" r="16" fill="none" stroke="#a855f7" stroke-width="1.5" id="src-glow-subsonic" class="opacity-0 transition-all duration-300"></circle>
          <!-- Subsonic Cloud Icon -->
          <g transform="translate(50, 230)" class="text-neutral-500" id="src-icon-subsonic">
            <path d="M -7,0 Q -9,-5 -5,-6 Q -2,-9 2,-6 Q 7,-6 7,0 Q 9,3 5,4 L -5,4 Q -9,3 -7,0 Z" fill="none" stroke="currentColor" stroke-width="1.2"></path>
            <circle cx="0" cy="0" r="1.5" fill="currentColor"></circle>
          </g>
          <text x="75" y="235" fill="#a3a3a3" font-family="monospace" font-size="11" id="src-text-subsonic" class="transition-colors duration-300">SUBSONIC</text>
        </g>

        <!-- Integrations (Sleek Glassmorphic Badges) -->
        <!-- REST API -->
        <g id="node-integration-api" class="transform hover:scale-105 transition-transform duration-300">
          <rect x="175" y="-2" width="90" height="24" rx="6" ry="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.2" class="shadow-glow-card"></rect>
          <!-- REST API Icon (Code Brackets) -->
          <g transform="translate(190, 10)" class="text-sky-400">
            <path d="M -4,-3.5 L -7,0 L -4,3.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M 4,-3.5 L 7,0 L 4,3.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
            <line x1="-1.5" y1="4.5" x2="1.5" y2="-4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
          </g>
          <text x="204" y="14" fill="#a3a3a3" font-family="monospace" font-size="10" text-anchor="start" letter-spacing="0.5">REST API</text>
        </g>

        <!-- D-Bus -->
        <g id="node-integration-dbus" class="transform hover:scale-105 transition-transform duration-300">
          <rect x="325" y="-2" width="110" height="24" rx="6" ry="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.2" class="shadow-glow-card"></rect>
          <!-- D-Bus Icon (IPC Nodes) -->
          <g transform="translate(340, 10)" class="text-purple-400">
            <circle cx="-4" cy="-3.5" r="1.5" fill="currentColor"></circle>
            <circle cx="4" cy="-3.5" r="1.5" fill="currentColor"></circle>
            <circle cx="0" cy="3.5" r="1.5" fill="currentColor"></circle>
            <line x1="-4" y1="-3.5" x2="0" y2="3.5" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.5"></line>
            <line x1="4" y1="-3.5" x2="0" y2="3.5" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.5"></line>
            <line x1="-4" y1="-3.5" x2="4" y2="-3.5" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.5"></line>
          </g>
          <text x="354" y="14" fill="#a3a3a3" font-family="monospace" font-size="10" text-anchor="start" letter-spacing="0.5">D-BUS/MPRIS</text>
        </g>

        <!-- MQTT -->
        <g id="node-integration-mqtt" class="transform hover:scale-105 transition-transform duration-300">
          <rect x="187" y="268" width="66" height="24" rx="6" ry="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.2" class="shadow-glow-card"></rect>
          <!-- MQTT Icon (Pub-Sub Hub) -->
          <g transform="translate(202, 280)" class="text-rose-400">
            <circle cx="0" cy="0" r="1.8" fill="currentColor"></circle>
            <circle cx="5.5" cy="4" r="1.2" fill="currentColor"></circle>
            <circle cx="5.5" cy="-4" r="1.2" fill="currentColor"></circle>
            <circle cx="-5.5" cy="0" r="1.2" fill="currentColor"></circle>
            <path d="M -4.3,0 L -1.8,0" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"></path>
            <path d="M 1.3,0.9 L 4.3,3.1" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"></path>
            <path d="M 1.3,-0.9 L 4.3,-3.1" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"></path>
          </g>
          <text x="216" y="284" fill="#a3a3a3" font-family="monospace" font-size="10" text-anchor="start" letter-spacing="0.5">MQTT</text>
        </g>

        <!-- KNX -->
        <g id="node-integration-knx" class="transform hover:scale-105 transition-transform duration-300">
          <rect x="337" y="268" width="86" height="24" rx="6" ry="6" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.2" class="shadow-glow-card"></rect>
          <!-- KNX Icon (Smart House) -->
          <g transform="translate(352, 280)" class="text-teal-400">
            <path d="M -6.5,-1 L 0,-6.5 L 6.5,-1" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M -4.5,-1 L -4.5,5.5 L 4.5,5.5 L 4.5,-1" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
            <circle cx="0" cy="1.5" r="1.2" fill="currentColor"></circle>
            <line x1="0" y1="1.5" x2="0" y2="5.5" stroke="currentColor" stroke-width="0.8"></line>
          </g>
          <text x="366" y="284" fill="#a3a3a3" font-family="monospace" font-size="10" text-anchor="start" letter-spacing="0.5">KNX BUS</text>
        </g>

        <!-- SnapDog Server Node -->
        <g id="node-server" class="cursor-pointer focus:outline-none" role="button" tabindex="0" aria-label="Toggle audio playback" aria-pressed="true">
          <!-- Outer border -->
          <rect x="250" y="110" width="100" height="80" rx="12" ry="12" fill="#0c0a09" stroke="rgba(255,255,255,0.08)" stroke-width="2" class="shadow-glow-card"></rect>
          <rect x="250" y="110" width="100" height="80" rx="12" ry="12" fill="none" stroke="#f59e0b" stroke-width="1" class="opacity-20"></rect>
          <!-- VU Meters / EQ bars inside server -->
          <g transform="translate(262, 130)" class="fill-amber-500/80">
            <rect id="vu-1" x="0" y="10" width="6" height="25" rx="1.5"></rect>
            <rect id="vu-2" x="10" y="15" width="6" height="20" rx="1.5"></rect>
            <rect id="vu-3" x="20" y="5" width="6" height="30" rx="1.5"></rect>
            <rect id="vu-4" x="30" y="22" width="6" height="13" rx="1.5"></rect>
            <rect id="vu-5" x="40" y="18" width="6" height="17" rx="1.5"></rect>
            <rect id="vu-6" x="50" y="8" width="6" height="27" rx="1.5"></rect>
            <rect id="vu-7" x="60" y="12" width="6" height="23" rx="1.5"></rect>
            <rect id="vu-8" x="70" y="2" width="6" height="33" rx="1.5"></rect>
          </g>
          <!-- Status Lamp -->
          <circle id="core-led" cx="340" cy="122" r="3" fill="#22c55e" class="animate-pulse"></circle>
          <text x="300" y="203" fill="#f59e0b" font-family="monospace" font-weight="bold" font-size="12" text-anchor="middle" letter-spacing="1.5">SNAPDOG CORE</text>
          <!-- Dynamic Active Input Status -->
          <text id="core-src-status" x="300" y="215" fill="#e5e5e5" font-family="monospace" font-size="9" text-anchor="middle">INPUT: AIRPLAY 2</text>
          <!-- Parametric EQ tag -->
          <text id="core-playback-status" x="300" y="227" fill="#a3a3a3" font-family="monospace" font-size="9" text-anchor="middle">DSP / 5-BAND EQ ACTIVE</text>
        </g>

        <!-- Room 1 (Living Room) Client -->
        <g id="node-room-1" class="cursor-pointer focus:outline-none" data-room="1" role="button" tabindex="0" aria-label="Toggle Living Room client zone" aria-pressed="true">
          <rect x="495" y="36" width="70" height="68" fill="none" pointer-events="all" class="cursor-pointer"></rect>
          <circle cx="530" cy="60" r="24" fill="#0f0f0f" stroke="#22c55e" stroke-width="1.5" id="c-circle-1"></circle>
          <circle cx="530" cy="60" r="14" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1"></circle>
          <!-- Status LED -->
          <circle cx="530" cy="60" r="3" fill="#22c55e" id="c-led-1"></circle>
          <!-- Speaker Icon geometry -->
          <path d="M 515,57 L 519,57 L 523,53 L 523,67 L 519,63 L 515,63 Z" fill="rgba(255,255,255,0.4)" id="c-icon-1"></path>
          <path d="M 526,57 C 528,58 528,62 526,63" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1" stroke-linecap="round" id="c-wave-1"></path>
          <text x="530" y="103" fill="#e5e5e5" font-family="monospace" font-size="10" text-anchor="middle" letter-spacing="0.5" id="c-text-1">LIVING ROOM</text>
        </g>

        <!-- Room 2 (Kitchen) Client -->
        <g id="node-room-2" class="cursor-pointer focus:outline-none" data-room="2" role="button" tabindex="0" aria-label="Toggle Kitchen client zone" aria-pressed="true">
          <rect x="495" y="116" width="70" height="68" fill="none" pointer-events="all" class="cursor-pointer"></rect>
          <circle cx="530" cy="140" r="24" fill="#0f0f0f" stroke="#22c55e" stroke-width="1.5" id="c-circle-2"></circle>
          <circle cx="530" cy="140" r="14" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1"></circle>
          <!-- Status LED -->
          <circle cx="530" cy="140" r="3" fill="#22c55e" id="c-led-2"></circle>
          <!-- Speaker Icon geometry -->
          <path d="M 515,137 L 519,137 L 523,133 L 523,147 L 519,143 L 515,143 Z" fill="rgba(255,255,255,0.4)" id="c-icon-2"></path>
          <path d="M 526,137 C 528,138 528,142 526,143" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1" stroke-linecap="round" id="c-wave-2"></path>
          <text x="530" y="183" fill="#e5e5e5" font-family="monospace" font-size="10" text-anchor="middle" letter-spacing="0.5" id="c-text-2">KITCHEN</text>
        </g>

        <!-- Room 3 (Patio) Client -->
        <g id="node-room-3" class="cursor-pointer focus:outline-none" data-room="3" role="button" tabindex="0" aria-label="Toggle Patio client zone" aria-pressed="false">
          <rect x="495" y="196" width="70" height="68" fill="none" pointer-events="all" class="cursor-pointer"></rect>
          <circle cx="530" cy="220" r="24" fill="#0f0f0f" stroke="rgba(255,255,255,0.1)" stroke-width="1.5" id="c-circle-3"></circle>
          <circle cx="530" cy="220" r="14" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1"></circle>
          <!-- Status LED -->
          <circle cx="530" cy="220" r="3" fill="#ea580c" id="c-led-3"></circle>
          <!-- Speaker Icon geometry -->
          <path d="M 515,217 L 519,217 L 523,213 L 523,227 L 519,223 L 515,223 Z" fill="rgba(255,255,255,0.2)" id="c-icon-3"></path>
          <path d="M 526,217 C 528,218 528,222 526,223" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-linecap="round" id="c-wave-3"></path>
          <text x="530" y="263" fill="#a3a3a3" font-family="monospace" font-size="10" text-anchor="middle" letter-spacing="0.5" id="c-text-3">PATIO</text>
        </g>
      </svg>
    </div>
  </div>
</section>

<style is:global>
  @keyframes flow-animation {
    to {
      stroke-dashoffset: -40;
    }
  }

  .flowing-line {
    stroke-dasharray: 10 10;
    animation: flow-animation 1.5s linear infinite;
  }

  /* SVG interactive node enhancements */
  #routing-svg g:focus {
    outline: none !important;
  }
  #routing-svg g:focus-visible {
    outline: none !important;
  }
  
  /* Modern accessible focus indicator for circles and rects */
  #routing-svg g:focus-visible circle:first-of-type,
  #routing-svg g:focus-visible rect:first-of-type {
    stroke: #fbbf24 !important;
    stroke-width: 2.5px !important;
    filter: drop-shadow(0 0 6px rgba(245, 158, 11, 0.6));
  }

  /* Robust hover effects (safely scale and brighten without layout displacement) */
  #routing-svg g.cursor-pointer {
    transition: opacity 0.2s ease;
  }
  #routing-svg g.cursor-pointer:hover circle:first-of-type,
  #routing-svg g.cursor-pointer:hover rect:first-of-type {
    stroke-width: 2.5px !important;
    filter: brightness(1.2) drop-shadow(0 0 4px currentColor);
  }

  /* Audio wire flow pause when playback is muted/paused */
  #routing-svg.paused .flowing-line {
    animation-play-state: paused !important;
  }
</style>

<script>
  // Room nodes configuration
  const roomNodes = [
    {
      group: document.getElementById('node-room-1'),
      path: document.getElementById('path-room-1'),
      circle: document.getElementById('c-circle-1'),
      led: document.getElementById('c-led-1'),
      icon: document.getElementById('c-icon-1'),
      wave: document.getElementById('c-wave-1'),
      text: document.getElementById('c-text-1'),
      name: 'LIVING ROOM'
    },
    {
      group: document.getElementById('node-room-2'),
      path: document.getElementById('path-room-2'),
      circle: document.getElementById('c-circle-2'),
      led: document.getElementById('c-led-2'),
      icon: document.getElementById('c-icon-2'),
      wave: document.getElementById('c-wave-2'),
      text: document.getElementById('c-text-2'),
      name: 'KITCHEN'
    },
    {
      group: document.getElementById('node-room-3'),
      path: document.getElementById('path-room-3'),
      circle: document.getElementById('c-circle-3'),
      led: document.getElementById('c-led-3'),
      icon: document.getElementById('c-icon-3'),
      wave: document.getElementById('c-wave-3'),
      text: document.getElementById('c-text-3'),
      name: 'PATIO'
    }
  ];

  // Source configuration state
  const sources: Record<string, {
    circle: HTMLElement | null;
    glow: HTMLElement | null;
    icon: HTMLElement | null;
    text: HTMLElement | null;
    path: HTMLElement | null;
    color: string;
    label: string;
    lineClass: string;
    grad: string;
  }> = {
    airplay: {
      circle: document.getElementById('src-circle-airplay'),
      glow: document.getElementById('src-glow-airplay'),
      icon: document.getElementById('src-icon-airplay'),
      text: document.getElementById('src-text-airplay'),
      path: document.getElementById('path-src-airplay'),
      color: '#f59e0b',
      label: 'AIRPLAY 2',
      lineClass: 'flowing-line',
      grad: 'url(#grad-amber-flow)'
    },
    spotify: {
      circle: document.getElementById('src-circle-spotify'),
      glow: document.getElementById('src-glow-spotify'),
      icon: document.getElementById('src-icon-spotify'),
      text: document.getElementById('src-text-spotify'),
      path: document.getElementById('path-src-spotify'),
      color: '#22c55e',
      label: 'SPOTIFY CONNECT',
      lineClass: 'flowing-line',
      grad: 'url(#grad-green-flow)'
    },
    radio: {
      circle: document.getElementById('src-circle-radio'),
      glow: document.getElementById('src-glow-radio'),
      icon: document.getElementById('src-icon-radio'),
      text: document.getElementById('src-text-radio'),
      path: document.getElementById('path-src-radio'),
      color: '#0ea5e9',
      label: 'WEB RADIO',
      lineClass: 'flowing-line',
      grad: 'url(#grad-blue-flow)'
    },
    subsonic: {
      circle: document.getElementById('src-circle-subsonic'),
      glow: document.getElementById('src-glow-subsonic'),
      icon: document.getElementById('src-icon-subsonic'),
      text: document.getElementById('src-text-subsonic'),
      path: document.getElementById('path-src-subsonic'),
      color: '#a855f7',
      label: 'SUBSONIC PLAY',
      lineClass: 'flowing-line',
      grad: 'url(#grad-purple-flow)'
    }
  };

  let currentSourceId = 'airplay';
  let currentRoomIndex = 0;
  let isPlaybackActive = true;

  const updateVisuals = () => {
    console.log('updateVisuals called. Source:', currentSourceId, 'Room Index:', currentRoomIndex);
    const activeSrc = sources[currentSourceId];
    if (!activeSrc) {
      console.error('activeSrc not found for:', currentSourceId);
      return;
    }

    // 1. Update source nodes and wires
    Object.keys(sources).forEach((srcId) => {
      const src = sources[srcId];
      if (!src) return;
      const isActive = srcId === currentSourceId;
      const nodeEl = document.getElementById(`node-src-${srcId}`);
      nodeEl?.setAttribute('aria-pressed', isActive.toString());

      if (isActive) {
        if (src.circle) {
          src.circle.style.stroke = src.color;
          src.circle.style.fill = 'rgba(255, 255, 255, 0.02)';
        }
        if (src.glow) {
          src.glow.style.opacity = '0.3';
          src.glow.classList.add('animate-pulse');
        }
        if (src.icon) {
          src.icon.style.color = src.color;
        }
        if (src.text) {
          src.text.style.fill = '#ffffff';
          src.text.style.fontWeight = 'bold';
        }
        if (src.path) {
          src.path.style.display = 'block';
          src.path.style.stroke = src.grad;
          src.path.style.strokeWidth = '3';
          src.path.className.baseVal = src.lineClass;
        }
      } else {
        if (src.circle) {
          src.circle.style.stroke = 'rgba(255, 255, 255, 0.08)';
          src.circle.style.fill = '#0f0f0f';
        }
        if (src.glow) {
          src.glow.style.opacity = '0';
          src.glow.classList.remove('animate-pulse');
        }
        if (src.icon) {
          src.icon.style.color = 'rgba(255, 255, 255, 0.3)';
        }
        if (src.text) {
          src.text.style.fill = '#737373';
          src.text.style.fontWeight = 'normal';
        }
        if (src.path) {
          src.path.style.display = 'none'; // Hide inactive source wires
        }
      }
    });

    // Update snapdog core active source label & status LED
    const statusText = document.getElementById('core-src-status');
    if (statusText) {
      statusText.textContent = `INPUT: ${activeSrc.label}`;
    }
    const coreLed = document.getElementById('core-led');
    const corePlaybackStatus = document.getElementById('core-playback-status');
    const coreNode = document.getElementById('node-server');

    if (isPlaybackActive) {
      if (coreLed) {
        coreLed.style.fill = '#22c55e';
        coreLed.classList.add('animate-pulse');
      }
      if (corePlaybackStatus) {
        corePlaybackStatus.textContent = 'DSP / 5-BAND EQ ACTIVE';
        corePlaybackStatus.style.fill = '#a3a3a3';
      }
      coreNode?.setAttribute('aria-pressed', 'true');
    } else {
      if (coreLed) {
        coreLed.style.fill = '#ea580c';
        coreLed.classList.remove('animate-pulse');
      }
      if (corePlaybackStatus) {
        corePlaybackStatus.textContent = 'PLAYBACK PAUSED';
        corePlaybackStatus.style.fill = '#ea580c';
      }
      coreNode?.setAttribute('aria-pressed', 'false');
    }

    // 2. Update room/zone nodes and wires
    roomNodes.forEach((room, idx) => {
      const isActive = idx === currentRoomIndex;
      const nodeEl = room.group;
      nodeEl?.setAttribute('aria-pressed', isActive.toString());

      if (isActive) {
        if (room.path) {
          room.path.style.display = 'block';
          room.path.style.stroke = activeSrc.grad; // Match active source gradient
          room.path.style.strokeWidth = '3';
          room.path.className.baseVal = activeSrc.lineClass;
        }
        if (room.circle) room.circle.style.stroke = activeSrc.color; // Match active source color
        if (room.led) room.led.style.fill = activeSrc.color;
        if (room.icon) {
          room.icon.style.fill = activeSrc.color;
          room.icon.style.opacity = '1';
        }
        if (room.wave) {
          room.wave.style.display = 'block';
          room.wave.style.stroke = activeSrc.color;
        }
        if (room.text) {
          room.text.textContent = room.name;
          room.text.style.fill = '#ffffff';
          room.text.style.fontWeight = 'bold';
        }
      } else {
        if (room.path) {
          room.path.style.display = 'none';
        }
        if (room.circle) room.circle.style.stroke = 'rgba(255, 255, 255, 0.1)';
        if (room.led) room.led.style.fill = '#ea580c'; // Red-orange mute status LED
        if (room.icon) {
          room.icon.style.fill = 'rgba(255, 255, 255, 0.2)';
          room.icon.style.opacity = '0.5';
        }
        if (room.wave) room.wave.style.display = 'none';
        if (room.text) {
          room.text.textContent = room.name;
          room.text.style.fill = '#a3a3a3';
          room.text.style.fontWeight = 'normal';
        }
      }
    });
  };

  // Helper listener registration
  const registerSource = (nodeId: string, id: string) => {
    const el = document.getElementById(nodeId);
    if (el) {
      el.addEventListener('click', () => {
        console.log('Source clicked:', id);
        currentSourceId = id;
        updateVisuals();
      });
      el.addEventListener('keydown', (e) => {
        if (e.key === ' ' || e.key === 'Enter') {
          e.preventDefault();
          console.log('Source keydown:', id);
          currentSourceId = id;
          updateVisuals();
        }
      });
    }
  };

  // Bind source elements
  registerSource('node-src-airplay', 'airplay');
  registerSource('node-src-spotify', 'spotify');
  registerSource('node-src-radio', 'radio');
  registerSource('node-src-subsonic', 'subsonic');

  // Bind room elements
  roomNodes.forEach((room, idx) => {
    room.group?.addEventListener('click', () => {
      console.log('Room clicked:', room.name, idx);
      currentRoomIndex = idx;
      updateVisuals();
    });
    room.group?.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        console.log('Room keydown:', room.name, idx);
        currentRoomIndex = idx;
        updateVisuals();
      }
    });
  });

  // Bind core element
  const coreNode = document.getElementById('node-server');
  if (coreNode) {
    const togglePlayback = () => {
      console.log('Core clicked, toggling playback. New state:', !isPlaybackActive);
      isPlaybackActive = !isPlaybackActive;
      
      const svgEl = document.getElementById('routing-svg');
      if (isPlaybackActive) {
        svgEl?.classList.remove('paused');
        if (!animationFrameId && isElementVisible) {
          updateVUMeter();
        }
      } else {
        svgEl?.classList.add('paused');
        // trigger one update to flatline and pause loop
        updateVUMeter();
      }
      updateVisuals();
    };

    coreNode.addEventListener('click', togglePlayback);
    coreNode.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        togglePlayback();
      }
    });
  }

  // Run initial state updates
  updateVisuals();

  // VU Meter Simulation loop (animating the height of the bars in snapdog server node)
  const vuBars = [
    document.getElementById('vu-1'),
    document.getElementById('vu-2'),
    document.getElementById('vu-3'),
    document.getElementById('vu-4'),
    document.getElementById('vu-5'),
    document.getElementById('vu-6'),
    document.getElementById('vu-7'),
    document.getElementById('vu-8')
  ];

  let animationFrameId: number | null = null;
  let isElementVisible = false;
  let time = 0;

  const updateVUMeter = () => {
    if (!isElementVisible) return;

    if (!isPlaybackActive) {
      // Flatline the VU bars when playback is paused
      vuBars.forEach((bar) => {
        if (bar) {
          bar.setAttribute('y', '31');
          bar.setAttribute('height', '4');
        }
      });
      animationFrameId = null;
      return;
    }

    time += 0.1;

    vuBars.forEach((bar, idx) => {
      if (bar) {
        const factor = 0.5 + 0.5 * Math.sin(time + idx * 0.7) * Math.cos(time * 0.5 - idx * 0.3);
        const height = 4 + 30 * factor;
        const y = 35 - height;
        bar.setAttribute('y', y.toString());
        bar.setAttribute('height', height.toString());
      }
    });

    animationFrameId = requestAnimationFrame(updateVUMeter);
  };

  const svgElement = document.getElementById('routing-svg');
  const observerContainer = svgElement?.closest('.glass-card');
  if (observerContainer) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        isElementVisible = entry.isIntersecting;
        if (isElementVisible) {
          if (!animationFrameId) {
            updateVUMeter();
          }
        } else {
          if (animationFrameId) {
            cancelAnimationFrame(animationFrameId);
            animationFrameId = null;
          }
        }
      });
    }, { threshold: 0.05 });

    observer.observe(observerContainer);
  }
</script>
